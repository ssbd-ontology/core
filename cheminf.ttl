            owl:onProperty :CHEMINF_000012 ;
            owl:someValuesFrom xsd:int ],
        [ a owl:Restriction ;
            owl:onProperty obo:IAO_0000136 ;
            owl:someValuesFrom obo:CHEBI_23367 ],
        :CHEMINF_000209 ;
    skos:definition "Size of largest chain"@en ;
    skos:prefLabel "SizeOfLargestChain"@en .

