    skos:prefLabel "HydrogenBondAcceptors(Daylight)"@en .

<http://semanticscience.org/resource/CHEMINF_001514> a owl:Class ;
    rdfs:label "acceptors or donors field atoms (Boehm,Klebe)"@en ;
