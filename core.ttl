    skos:prefLabel "AcceptorsOrDonorsFieldAtoms(Boehm,Klebe)"@en .

<http://semanticscience.org/resource/CHEMINF_001515> a owl:Class ;
    rdfs:label "donor field atoms (Boehm,Klebe)"@en ;
