    skos:definition "Maximal ratio of length to breadth descriptor"@en ;
    skos:prefLabel "MaximalRatioOfLengthToBreadthDescriptor"@en .

<http://semanticscience.org/resource/CHEMINF_000190> a owl:Class ;
