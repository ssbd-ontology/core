    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000411">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000464"/>
        <rdfs:label xml:lang="en">Reactome identifier</rdfs:label>
        <skos:definition xml:lang="en">Database identifier used by Reactome.</skos:definition>
        <skos:prefLabel xml:lang="en">ReactomeIdentifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000412 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000412">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000464"/>
        <rdfs:label xml:lang="en">ChEMBL identifier</rdfs:label>
        <skos:definition xml:lang="en">Identifier used by the ChEMBL database for compounds, assays, target, etc.</skos:definition>
        <skos:prefLabel xml:lang="en">ChEMBLIdentifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000413 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000413">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <obo:IAO_0000117>Colin Batchelor</obo:IAO_0000117>
        <rdfs:label xml:lang="en">organic carbon adsorption descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the ratio of the amount of a given chemical substance
    adsorbed per unit weight of organic carbon in soil or sediment to the concentration
    of the chemical substance in solution at equilibrium.
    </skos:definition>
        <skos:prefLabel xml:lang="en">OrganicCarbonAdsorptionDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000414 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000414">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000117>Colin Batchelor</obo:IAO_0000117>
        <rdfs:label xml:lang="en">bioconcentration factor descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the ratio of the concentration of a chemical substance in an organism immersed in water to that in the surrounding water at equilibrium.</skos:definition>
        <skos:prefLabel xml:lang="en">BioconcentrationFactorDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000415 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000415">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <obo:IAO_0000117>Colin Batchelor</obo:IAO_0000117>
        <rdfs:label xml:lang="en">molar volume descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the volume occupied by one mole of the given substance at a given temperature and pressure.</skos:definition>
        <skos:prefLabel xml:lang="en">MolarVolumeDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000416 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000416">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000117>Colin Batchelor</obo:IAO_0000117>
        <rdfs:label xml:lang="en">density descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the density of a given substance at a given temperature and pressure.</skos:definition>
        <skos:prefLabel xml:lang="en">DensityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000417 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000417">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000117>Colin Batchelor</obo:IAO_0000117>
        <rdfs:label xml:lang="en">flash point descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the flash point of a substance at a given pressure.
    The flash point is the minimum temperature at which a mixture of the substance with air can be ignited, within its explosive range.</skos:definition>
        <skos:prefLabel xml:lang="en">FlashPointDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000418 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000418">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <obo:IAO_0000117>Colin Batchelor</obo:IAO_0000117>
        <rdfs:label xml:lang="en">enthalpy of vaporization descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the energy taken in by a chemical substance on vaporization at a given temperature and pressure.</skos:definition>
        <skos:prefLabel xml:lang="en">EnthalpyOfVaporizationDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000419 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000419">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <obo:IAO_0000117>Colin Batchelor</obo:IAO_0000117>
        <rdfs:label xml:lang="en">vapour pressure descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the pressure exerted by the vapour phase of a chemical substance on its condensed phase at a given temperature and pressure.</skos:definition>
        <skos:prefLabel xml:lang="en">VapourPressureDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000420 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000420">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <obo:IAO_0000117>Colin Batchelor</obo:IAO_0000117>
        <rdfs:label xml:lang="en">surface tension descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the disposition of a portion of liquid to resist a force.</skos:definition>
        <skos:prefLabel xml:lang="en">SurfaceTensionDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000430 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000430">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <obo:IAO_0000115>The number of structural alerts, that is, unwanted features as defined according to the procedure followed in Brenk et al., 2008. 
Brenk R, et al. Lessons learnt from assembling screening libraries for drug discovery for neglected diseases. Chem Med Chem. 2008;3:435–444. </obo:IAO_0000115>
        <skos:definition xml:lang="en">Structural alert count</skos:definition>
        <skos:prefLabel xml:lang="en">StructuralAlertCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000431 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000431">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <obo:IAO_0000115>A descriptor which gives a quantitative estimate of drug likeness according to the procedure outlined in Bickerton et al., 2012. 

http://www.ncbi.nlm.nih.gov/pubmed/22270643
Nat Chem. 2012 Jan 24;4(2):90-8. doi: 10.1038/nchem.1243.
Quantifying the chemical beauty of drugs.
Bickerton GR, Paolini GV, Besnard J, Muresan S, Hopkins AL.</obo:IAO_0000115>
        <obo:IAO_0000118>QED weighted</obo:IAO_0000118>
        <skos:definition xml:lang="en">Weighted quantitative estimate of drug-likeness</skos:definition>
        <skos:prefLabel xml:lang="en">WeightedQuantitativeEstimateOfDrugMinuslikeness</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000432 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000432">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">freezing point descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor that indicates the temperature at which a chemical substance undergoes a state transition from gas or liquid to solid, under standard conditions.</skos:definition>
        <skos:prefLabel xml:lang="en">FreezingPointDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000433 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000433">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Henry&apos;s Law constant</rdfs:label>
        <skos:definition xml:lang="en">Henry&apos;s law, formulated by William Henry in 1803, states &quot;At a constant temperature, the amount of a given gas that dissolves in a given type and volume of liquid is directly proportional to the partial pressure of that gas in equilibrium with that liquid.&quot; Henry&apos;s law can be put into mathematical terms (at constant temperature) as
    p = kHc
where p is the partial pressure of the solute in the gas above the solution, c is the concentration of the solute and kH is a constant with the dimensions of pressure divided by concentration. The constant, known as the Henry&apos;s law constant, depends on the solute, the solvent and the temperature.</skos:definition>
        <skos:prefLabel xml:lang="en">HenrysLawConstant</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000434 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000434">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atmospheric OH rate constant</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor for the rate constant of a reaction of a chemical entity with OH. This is used to describe the atmospheric behaviour (i.e. stability) of the entity. </skos:definition>
        <skos:prefLabel xml:lang="en">AtmosphericOHRateConstant</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000435 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000435">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">upper explosive limit descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor for the upper explosive limit of the entity in air as a percentage by volume at room temperature. </skos:definition>
        <skos:prefLabel xml:lang="en">UpperExplosiveLimitDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000436 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000436">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">lower explosive limit descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor for the lower explosive limit in air as a percentage by volume at room temperature</skos:definition>
        <skos:prefLabel xml:lang="en">LowerExplosiveLimitDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000437 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000437">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">minimum explosive concentration descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor for the minimum explosive concentration. </skos:definition>
        <skos:prefLabel xml:lang="en">MinimumExplosiveConcentrationDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000438 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000438">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">specific gravity descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor of the ratio of the density of chemical substance to the density of a reference substance. The reference substance is usually water for liquids or air for gases. </skos:definition>
        <skos:prefLabel xml:lang="en">SpecificGravityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000439 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000439">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">relative density descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the relative density of gases referenced to air as 1, which indicates how many times a gas is heavier than air at the same temperature. </skos:definition>
        <skos:prefLabel xml:lang="en">RelativeDensityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000440 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000440">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">vapor density descriptor</rdfs:label>
        <skos:definition xml:lang="en">A descriptor of the density of a vapour in relation in that of hydrogen, defined as the mass of a certain volume of the given substance divided by the mass of the same volume of hydrogen. </skos:definition>
        <skos:prefLabel xml:lang="en">VaporDensityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000441 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000441">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">odor detection threshold descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor for the lowest concentration of an odorant chemical entity that is perceivable by the human sense of smell. </skos:definition>
        <skos:prefLabel xml:lang="en">OdorDetectionThresholdDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000442 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000442">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pH descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor which gives a measure of the acidity or basicity of an aqueous solution, defined as the decimal logarithm of the reciprocal of the hydrogen ion activity in a solution. </skos:definition>
        <skos:prefLabel xml:lang="en">PHDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000443 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000443">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">evaporation rate descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor of the rate of evaporation of a liquid under standard conditions. </skos:definition>
        <skos:prefLabel xml:lang="en">EvaporationRateDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000444 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000444">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000118>kindling point</obo:IAO_0000118>
        <rdfs:label xml:lang="en">autoignition temperature descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor of the lowest temperature at a substance will spontaneously ignite in a normal atmosphere without an external source of ignition. </skos:definition>
        <skos:prefLabel xml:lang="en">AutoignitionTemperatureDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000445 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000445">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">soil half-life descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor for the time it takes for half of a portion of substance of a given type to decompose in soil under standard conditions. </skos:definition>
        <skos:prefLabel xml:lang="en">SoilHalfMinuslifeDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000446 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000446">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000464"/>
        <rdfs:label xml:lang="en">CAS registry number</rdfs:label>
        <skos:definition xml:lang="en">Identifier used by the Chemical Abstracts Service database.</skos:definition>
        <skos:prefLabel xml:lang="en">CASRegistryNumber</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000447 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000447">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000464"/>
        <rdfs:label xml:lang="en">EC number</rdfs:label>
        <rdfs:label xml:lang="en">EINECS No</rdfs:label>
        <rdfs:label xml:lang="en">European Community number</rdfs:label>
        <skos:definition xml:lang="en">A seven-digit identifier for chemical substances for regulatory purposes within the European Union.</skos:definition>
        <skos:prefLabel xml:lang="en">ECNumber</skos:prefLabel>
        <skos:prefLabel xml:lang="en">EINECSNo</skos:prefLabel>
        <skos:prefLabel xml:lang="en">EuropeanCommunityNumber</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000448 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000448">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000263"/>
        <obo:IAO_0000115>A descriptor that specifies the integer count of metal atoms in a given chemical entity. </obo:IAO_0000115>
        <skos:definition xml:lang="en">Metal atom count</skos:definition>
        <skos:prefLabel xml:lang="en">MetalAtomCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000449 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000449">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000263"/>
        <obo:IAO_0000115>A descriptor that specifies the integer count of oxygen atoms in a given chemical entity. </obo:IAO_0000115>
        <skos:definition xml:lang="en">Oxygen atom count</skos:definition>
        <skos:prefLabel xml:lang="en">OxygenAtomCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000464 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000464">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000061"/>
