        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000136"/>
        <rdfs:label xml:lang="en">group of an atom</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that returns the group in the periodic table of a given atom.</skos:definition>
        <skos:prefLabel xml:lang="en">GroupOfAnAtom</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000517 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000517">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">NInChI descriptor</rdfs:label>
        <skos:definition xml:lang="en">An InChI-like descriptor for nanomaterials.</skos:definition>
        <skos:prefLabel xml:lang="en">NInChIDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000518 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000518">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000061"/>
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_36357"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">TUCAN descriptor</rdfs:label>
        <skos:definition xml:lang="en">TUCAN is an identifier based on a canonicalization and serialization algorithm that is independent of domain-specific concepts of structure and bonding.</skos:definition>
        <skos:prefLabel xml:lang="en">TUCANDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000519 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000519">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000027"/>
        <terms:creator rdf:resource="http://orcid.org/0000-0002-4378-6061"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-07-11T08:01:45+00:00</terms:date>
        <terms:source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://doi.org/10.1351/goldbook.A00020</terms:source>
        <rdfs:label xml:lang="en">absolute configuration stereochemical descriptor</rdfs:label>
        <skos:definition xml:lang="en">The spatial arrangement of the atoms of a chiral molecular entity (or group) and its stereochemical description e.g. R or S.</skos:definition>
        <skos:prefLabel xml:lang="en">AbsoluteConfigurationStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000520 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000520">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000027"/>
        <terms:creator rdf:resource="http://orcid.org/0000-0002-4378-6061"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-07-11T08:04:08+00:00</terms:date>
        <terms:source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://doi.org/10.1351/goldbook.R05260</terms:source>
        <rdfs:label xml:lang="en">relative configuration stereochemical descriptor</rdfs:label>
        <skos:definition xml:lang="en">The configuration of any stereogenic (asymmetric) centre with respect to any other stereogenic centre contained within the same molecular entity. Unlike absolute configuration, relative configuration is reflection-invariant. Relative configuration, distinguishing diastereoisomers, may be denoted by the configurational descriptors R*, R* (or l) and R*, S* (or u) meaning, respectively, that the two centres have identical or opposite configurations. For molecules with more than two asymmetric centres the prefix rel- may be used in front of the name of one enantiomer where R and S have been used. If any centres have known absolute configuration then only R* and S* can be used for the relative configuration.</skos:definition>
        <skos:prefLabel xml:lang="en">RelativeConfigurationStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000523 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000523">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000043"/>
        <obo:IAO_0000118>index name</obo:IAO_0000118>
        <terms:creator rdf:resource="http://orcid.org/0000-0002-4378-6061"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-07-11T08:20:10+00:00</terms:date>
        <terms:source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.acdlabs.com/products/name/</terms:source>
        <rdfs:label xml:lang="en">ACD/Labs index name</rdfs:label>
        <skos:definition xml:lang="en">A molecular entity name that represents the name of a molecular structure determined by the naming algorithms developed by ACD/Labs.</skos:definition>
        <skos:prefLabel xml:lang="en">ACDLabsIndexName</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000524 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000524">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000113"/>
        <terms:creator rdf:resource="http://orcid.org/0000-0002-4378-6061"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-07-11T08:22:02+00:00</terms:date>
        <terms:source rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://doi.org/10.1186%2Fs13321-015-0068-4</terms:source>
        <rdfs:label xml:lang="en">InChI with fixedH layer</rdfs:label>
        <skos:definition xml:lang="en">An InChI descriptor that is not the standard and that is created with the fixedH layer option. The fixedH layer is appended to the standard InChI and lists the exact position of the tautomeric hydrogen atoms. It is useful when one wants to represent a specific tautomer of a given structure, because if the InChIs for the tautomers were created without the fixedH layer option, the normalization performed by the InChI generation program would result in these InChIs being identical.</skos:definition>
        <skos:prefLabel xml:lang="en">InChIWithFixedHLayer</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000550 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000550">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000044"/>
        <obo:IAO_0000115>A ChEBI name is a preferred name annotated by the ChEBI database.  The ChEBI name has the additional feature that it is unique within the ChEBI dataset. </obo:IAO_0000115>
        <skos:definition xml:lang="en">ChEBI name</skos:definition>
        <skos:prefLabel xml:lang="en">ChEBIName</skos:prefLabel>
    </owl:Class>
    


