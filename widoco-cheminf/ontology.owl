    <!-- http://purl.obolibrary.org/obo/CHEBI_23367 -->


    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_23367">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000000"/>
        <oboInOwl:hasAlternativeId>CHEBI:23367</oboInOwl:hasAlternativeId>
        <skos:definition xml:lang="en">Molecular entity</skos:definition>
        <skos:prefLabel xml:lang="en">MolecularEntity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_33250 -->


    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_33250">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000000"/>
        <oboInOwl:hasAlternativeId>CHEBI:33250</oboInOwl:hasAlternativeId>
        <rdfs:label xml:lang="en">atom</rdfs:label>
        <skos:prefLabel xml:lang="en">Atom</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/CHEBI_36357 -->


    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CHEBI_36357">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
        <oboInOwl:hasAlternativeId>CHEBI:36357</oboInOwl:hasAlternativeId>
        <skos:definition xml:lang="en">Polyatomic entity</skos:definition>
        <skos:prefLabel xml:lang="en">PolyatomicEntity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000000 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000000">
        <oboInOwl:hasAlternativeId>CHEBI:24431</oboInOwl:hasAlternativeId>
        <oboInOwl:hasAlternativeId>obo:24431</oboInOwl:hasAlternativeId>
        <rdfs:label xml:lang="en">chemical entity</rdfs:label>
        <skos:definition xml:lang="en">A chemical entity is any molecular entity or chemical substance.</skos:definition>
        <skos:prefLabel xml:lang="en">ChemicalEntity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000001 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000001">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000094"/>
        <rdfs:label xml:lang="en">molar refractivity</rdfs:label>
        <skos:definition xml:lang="en">Molar refractviity is a measure of the total polarizability of a mole of a substance and is dependent on the temperature, the index of refraction, and the pressure.</skos:definition>
        <skos:prefLabel xml:lang="en">MolarRefractivity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000002 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000002">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000094"/>
        <rdfs:label xml:lang="en">atomic polarizability sum</rdfs:label>
        <skos:definition xml:lang="en">atomic polarizability sum is the sum of the atomic polarizabilities (including implicit hydrogens).</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicPolarizabilitySum</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000003 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000003">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">partial positive surface area</rdfs:label>
        <skos:altLabel xml:lang="en">PPSA-1</skos:altLabel>
        <skos:definition xml:lang="en">sum of surface area on positive parts of molecule</skos:definition>
        <skos:prefLabel xml:lang="en">PartialPositiveSurfaceArea</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000004 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000004">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">PPSA-2</rdfs:label>
        <skos:altLabel xml:lang="en">PPSA-2</skos:altLabel>
        <skos:definition xml:lang="en">partial positive surface area * total positive charge on the molecule</skos:definition>
        <skos:prefLabel xml:lang="en">PPSAMinus2</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000005 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000005">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000519"/>
        <skos:definition xml:lang="en">RS stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">RSStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000006 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000006">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000005"/>
        <owl:disjointWith rdf:resource="http://semanticscience.org/resource/CHEMINF_000034"/>
        <skos:definition xml:lang="en">R stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">RStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000007 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000007">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000018"/>
        <rdfs:label xml:lang="en">canonical SMILES descriptor</rdfs:label>
        <skos:definition xml:lang="en">A canonical SMILES descriptor is a SMILES descriptor that is produced using a canonicalization algorithm which results in one special generic SMILES among all valid possibilities.</skos:definition>
        <skos:prefLabel xml:lang="en">CanonicalSMILESDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000008 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000008">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">charge weighted partial positive surface area</rdfs:label>
        <skos:altLabel xml:lang="en">PPSA-3</skos:altLabel>
        <skos:definition xml:lang="en">charge weighted partial positive surface area</skos:definition>
        <skos:prefLabel xml:lang="en">ChargeWeightedPartialPositiveSurfaceArea</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000010 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000010">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000041"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atomic order</rdfs:label>
        <skos:definition xml:lang="en">Atomic order is an atomic descriptor that specifies the ordinal position of an atom.</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicOrder</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000011 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000011">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">partial negative surface area</rdfs:label>
        <skos:altLabel xml:lang="en">PNSA-1</skos:altLabel>
        <skos:definition xml:lang="en">sum of surface area on negative parts of molecule</skos:definition>
        <skos:prefLabel xml:lang="en">PartialNegativeSurfaceArea</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000015 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000015">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">PNSA-2</rdfs:label>
        <skos:altLabel xml:lang="en">PNSA-2</skos:altLabel>
        <skos:definition xml:lang="en">partial negative surface area * total negative charge on the molecule</skos:definition>
        <skos:prefLabel xml:lang="en">PNSAMinus2</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000016 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000016">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <rdfs:label xml:lang="en">energetic descriptor</rdfs:label>
        <skos:definition xml:lang="en">An energetic descriptor is a chemical descriptor which captures information about some aspect of the energetic behaviour of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">EnergeticDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000018 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000018">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">SMILES descriptor</rdfs:label>
        <skos:definition xml:lang="en">A SMILES descriptor is a structure descriptor that denotes a molecular structure as a graph.</skos:definition>
        <skos:prefLabel xml:lang="en">SMILESDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000019 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000019">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">SMARTS descriptor</rdfs:label>
        <skos:definition xml:lang="en">A SMARTS descriptor is a molecular structure descriptor that conforms to the SMARTS specification.</skos:definition>
        <skos:prefLabel xml:lang="en">SMARTSDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000025 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000025">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <rdfs:label xml:lang="en">physical descriptor</rdfs:label>
        <skos:definition xml:lang="en">A physical descriptor is a chemical descriptor which describes some physical property (quality or disposition) of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">PhysicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000027 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000027">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <rdfs:label xml:lang="en">stereochemical descriptor</rdfs:label>
        <skos:definition xml:lang="en">A stereochemical descriptor is a chemical descriptor which describes some aspect of the three dimensional structure of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">StereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000032 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000032">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000018"/>
        <rdfs:label xml:lang="en">isomeric SMILES descriptor</rdfs:label>
        <skos:definition xml:lang="en">an isomeric SMILES descriptor is a SMILES descriptor that written with isotopic and chiral specifications.</skos:definition>
        <skos:prefLabel xml:lang="en">IsomericSMILESDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000034 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000034">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000005"/>
        <skos:definition xml:lang="en">S stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">SStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000041 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000041">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <rdfs:label xml:lang="en">positional descriptor</rdfs:label>
        <skos:definition xml:lang="en">A positional descriptor is a chemical descriptor which describes some aspect of the position, or location of a chemical entity, or of the relative parts of a chemical entity with respct to one another.</skos:definition>
        <skos:prefLabel xml:lang="en">PositionalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000042 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000042">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000136"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">molecular formula</rdfs:label>
        <skos:definition xml:lang="en">A molecular formula is a structure descriptor which identifies each constituent element by its chemical symbol and indicates the number of atoms of each element found in each discrete molecule of that compound.</skos:definition>
        <skos:prefLabel xml:lang="en">MolecularFormula</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000043 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000043">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000061"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">molecular entity name</rdfs:label>
        <skos:definition xml:lang="en">An information entity about a molecular entity which serves to name that molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">MolecularEntityName</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000044 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000044">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000043"/>
        <rdfs:label xml:lang="en">preferred name</rdfs:label>
        <skos:definition xml:lang="en">A preferred name is a molecular entity name which is preferred, or recommended, for usage in textual annotations referring to that molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">PreferredName</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000046 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000046">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:label xml:lang="en">zagreb index</rdfs:label>
        <skos:definition xml:lang="en">The sum of the squared atom degrees of all heavy atoms.</skos:definition>
        <skos:prefLabel xml:lang="en">ZagrebIndex</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000048 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000048">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000520"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">+/- stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">PlusMinusStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000049 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000049">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000048"/>
        <owl:disjointWith rdf:resource="http://semanticscience.org/resource/CHEMINF_000050"/>
        <skos:definition xml:lang="en">+ stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">PlusStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000050 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000050">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000048"/>
        <skos:definition xml:lang="en">- stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">MinusStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000051 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000051">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000520"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">DL stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">DLStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000052 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000052">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000051"/>
        <owl:disjointWith rdf:resource="http://semanticscience.org/resource/CHEMINF_000053"/>
        <skos:definition xml:lang="en">D stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">DStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000053 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000053">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000051"/>
        <skos:definition xml:lang="en">L stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">LStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000055 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000055">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">chemical connectivity table</rdfs:label>
        <skos:definition xml:lang="en">A chemical connectivity table is a structure descriptor which consists of a connection table representing bonds between atoms in a molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">ChemicalConnectivityTable</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000056 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000056">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aromaticity descriptor</rdfs:label>
        <skos:definition xml:lang="en">An aromaticity descriptor is a chemical descriptor which indicates the aromaticity of a molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">AromaticityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000057 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000057">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <terms:creator rdf:resource="http://orcid.org/0000-0003-3465-8786"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2017-02-09T14:29:12+00:00</terms:date>
        <rdfs:label xml:lang="en">file</rdfs:label>
        <rdfs:label xml:lang="en">melt mass flow rate</rdfs:label>
        <skos:prefLabel xml:lang="en">File</skos:prefLabel>
        <skos:prefLabel xml:lang="en">MeltMassFlowRate</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000058 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000058">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000057"/>
        <rdfs:label xml:lang="en">MOLfile</rdfs:label>
        <skos:definition xml:lang="en">A MOLfile is a file which contains a MOLfile encoding of a chemical structure representation. It is the concretization of a MOLfile descriptor.</skos:definition>
        <skos:prefLabel xml:lang="en">MOLfile</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000059 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000059">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000061"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_36357"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">InChIKey</rdfs:label>
        <skos:prefLabel xml:lang="en">InChIKey</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000060 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000060">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000093"/>
        <rdfs:label xml:lang="en">dimensional extent descriptor</rdfs:label>
        <skos:definition xml:lang="en">A dimensional extent descriptor is a physical property descriptor which describes some measurable length, area or volume aspect of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">DimensionalExtentDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000061 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000061">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <rdfs:label xml:lang="en">identifying descriptor</rdfs:label>
        <skos:definition xml:lang="en">An identifying descriptor is a chemical descriptor which provides an identifier for the chemical entity it is about, which in most cases should aim to be unique and easy to use as an unambiguous reference for the chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">IdentifyingDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000062 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000062">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000093"/>
        <rdfs:label xml:lang="en">bond order descriptor</rdfs:label>
        <skos:definition xml:lang="en">A bond order descriptor is a descriptor associated with a bond in a chemical entity which indicates the order of the bond (single, double or triple).</skos:definition>
        <skos:prefLabel xml:lang="en">BondOrderDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000064 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000064">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <oboInOwl:hasAlternativeId>BODO:Descriptor</oboInOwl:hasAlternativeId>
        <rdfs:comment xml:lang="en">NOTE: QSAR descriptors are often just called &apos;chemical descriptor&apos; or &apos;molecular descriptor&apos; in the cheminformatics community.</rdfs:comment>
        <rdfs:label xml:lang="en">QSAR descriptor</rdfs:label>
        <skos:definition xml:lang="en">A Quantitative Structure Activity Relationship (QSAR) descriptor is a chemical descriptor which gives a numeric, quantitative value which is believed to be associated with some aspect of the chemical or biological activity of the chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">QSARDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000068 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000068">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">functional group descriptor</rdfs:label>
        <skos:definition xml:lang="en">A functional group descriptor is a structural descriptor which describes specific groups of atoms within molecules that are responsible for the characteristic chemical reactions of those molecules.</skos:definition>
        <skos:prefLabel xml:lang="en">FunctionalGroupDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000078 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000078">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">neutron count</rdfs:label>
        <skos:definition xml:lang="en">The (integer) number of neutrons in the atoms nucleus.</skos:definition>
        <skos:prefLabel xml:lang="en">NeutronCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000079 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000079">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">proton count</rdfs:label>
        <skos:definition xml:lang="en">The (integer) number of protons in the atoms nucleus.</skos:definition>
        <skos:prefLabel xml:lang="en">ProtonCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000080 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000080">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000520"/>
        <skos:definition xml:lang="en">Cis-trans stereochemical descriptor</skos:definition>
        <skos:definition xml:lang="en">Descriptors which show the relationship between two ligands attached to separate atoms that are connected by a double bond or are contained in a ring. The two ligands are said to be located cis to each other if they lie on the same side of a plane. If they are on opposite sides, their relative position is described as trans. The appropriate reference plane of a double bond is perpendicular to that of the relevant s-bonds and passes through the double bond.[source:IUPAC Gold Book - http://goldbook.iupac.org/C01092.html]</skos:definition>
        <skos:prefLabel xml:lang="en">CisMinustransStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000081 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000081">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000080"/>
        <skos:definition xml:lang="en">Cis stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">CisStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000082 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000082">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000080"/>
        <skos:definition xml:lang="en">Trans stereochemical descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">TransStereochemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000083 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000083">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Mass descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">MassDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000084 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000084">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000083"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Atomic mass descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicMassDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000085 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000085">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <rdfs:label xml:lang="en">structural descriptor</rdfs:label>
        <skos:definition xml:lang="en">A structural descriptor is a chemical descriptor which is about some aspect of the molecular structure (composition) of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">StructuralDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000087 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000087">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <skos:definition xml:lang="en">Electronic descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">ElectronicDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000088 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000088">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000083"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_36357"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>The mass of a molecule calculated according to some assumption about the isotopic identity of the atoms constituting it.</obo:IAO_0000115>
        <obo:IAO_0000117>Person: Colin Batchelor</obo:IAO_0000117>
        <skos:definition xml:lang="en">Molecular mass descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">MolecularMassDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000090 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000090">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atomic degree</rdfs:label>
        <skos:definition xml:lang="en">The integer number of non-H substituents of an atom.</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicDegree</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000092 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000092">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <rdfs:label xml:lang="en">topological descriptor</rdfs:label>
        <skos:definition xml:lang="en">A topological descriptor is a chemical descriptor which pertains to spatial properties of a geometric object that are preserved under continuous deformations of objects, for example, deformations that involve stretching.</skos:definition>
        <skos:prefLabel xml:lang="en">TopologicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000093 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000093">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <rdfs:label xml:lang="en">geometric descriptor</rdfs:label>
        <skos:definition xml:lang="en">A geometric descriptor is a descriptor that concerns information about size, shape, and relative position.</skos:definition>
        <skos:prefLabel xml:lang="en">GeometricDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000094 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000094">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <skos:definition xml:lang="en">Charge delocalization descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">ChargeDelocalizationDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000095 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000095">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">hybridization descriptor</rdfs:label>
        <skos:definition xml:lang="en">A hybridization descriptor is a chemical descriptor that is about the hybridization of atomic orbitals in a molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">HybridizationDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000096 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000096">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atomic valence</rdfs:label>
        <skos:definition xml:lang="en">Atomic valence is an atomic descriptor that specifies the maximum number of univalent atoms (originally hydrogen or chlorine atoms) which may combine with an atom of the element under consideration, or with a fragment, or for which an atom of this element can be substituted [source: IUPAC Gold Book - http://goldbook.iupac.org/V06588.html]</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicValence</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000097 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000097">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000094"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atomic hardness descriptor</rdfs:label>
        <skos:definition xml:lang="en">An atomic hardness descriptor is an atomic descriptor that estimates the difference between the ionization potential and the electron affinity of a given atom.</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicHardnessDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000099 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000099">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000094"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atomic softness descriptor</rdfs:label>
        <skos:definition xml:lang="en">An atomic softness descriptor is an atomic descriptor which is about the charge delocalizing ability of a given atom.</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicSoftnessDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000104 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000104">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000064"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">molecular QSAR descriptor</rdfs:label>
        <skos:definition xml:lang="en">A molecular QSAR descriptor is a OSAR descriptor which gives a quantitative value to some aspect of a molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">MolecularQSARDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000105 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000105">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:label xml:lang="en">cycle basis</rdfs:label>
        <skos:definition xml:lang="en">The cycle basis of a molecular structure is the smallest set of cycles (closed paths) formed in the graph representation of the structure, from which all other cycles can be computed.</skos:definition>
        <skos:prefLabel xml:lang="en">CycleBasis</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000106 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000106">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000043"/>
        <rdfs:label xml:lang="en">systematic name</rdfs:label>
        <skos:definition xml:lang="en">A systematic name is a molecular entity name which is formulated systematically from the structure of the molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">SystematicName</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000107 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000107">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000106"/>
        <rdfs:label xml:lang="en">IUPAC name</rdfs:label>
        <skos:definition xml:lang="en">An IUPAC name is a systematic name which is formulated according to the rules and recommendations for chemical nomenclature set out by the International Union of Pure and Applied Chemistry (IUPAC).</skos:definition>
        <skos:prefLabel xml:lang="en">IUPACName</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000109 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000109">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000043"/>
        <rdfs:label xml:lang="en">trivial name</rdfs:label>
        <skos:definition xml:lang="en">A trivial name is a molecular entity name that is in common public use and may not be related to the structure of the molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">TrivialName</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000110 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000110">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fused cycles</rdfs:label>
        <skos:definition xml:lang="en">The fused cycles in a molecular structure are those cycles from the cycle basis which share at least one bond.</skos:definition>
        <skos:prefLabel xml:lang="en">FusedCycles</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000112 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000112">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000064"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atomic QSAR descriptor</rdfs:label>
        <skos:definition xml:lang="en">An atomic QSAR descriptor is a QSAR descriptor which gives a quantitative value to some aspect of an atom which is part of a molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicQSARDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000113 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000113">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">InChI descriptor</rdfs:label>
        <skos:definition xml:lang="en">An InChI descriptor is a structure descriptor which conforms to the InChI format specification.</skos:definition>
        <skos:prefLabel xml:lang="en">InChIDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000114 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000114">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">MOLfile descriptor</rdfs:label>
        <skos:definition xml:lang="en">A MOLfile descriptor is a structure descriptor which conforms to the MOLfile format specification.</skos:definition>
        <skos:prefLabel xml:lang="en">MOLfileDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000116 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000116">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000093"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atomic connectivity index</rdfs:label>
        <skos:definition xml:lang="en">An atomic connectivity index is an atomic descriptor that is a measure of atomic connectivity, which can take various forms (e.g. zero-order, or first-order).</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicConnectivityIndex</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000117 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000117">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <rdfs:label xml:lang="en">Wiener path number</rdfs:label>
        <skos:definition xml:lang="en">Half the sum of all the distance matrix entries, topological index of atom-atom distances.</skos:definition>
        <skos:prefLabel xml:lang="en">WienerPathNumber</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000118 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000118">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">formal charge descriptor</rdfs:label>
        <skos:definition xml:lang="en">The formal charge gives the charge assigned to an atom in a molecule, assuming that electrons in a chemical bond are shared equally between atoms, regardless of relative electronegativity.
The formal charge of any atom in a molecule can be calculated by the following equation: FC = number of valence electrons of the atom in isolation (atom in ground state) - number of non-bonding electrons on this atom in the molecule - half the total number of electrons shared in covalent bonds with other atoms in the molecule. [source:wikipedia]</skos:definition>
        <skos:prefLabel xml:lang="en">FormalChargeDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000119 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000119">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">partial charge descriptor</rdfs:label>
        <skos:definition xml:lang="en">A partial charge descriptor gives the charge with an absolute value of less than one elementary charge unit (that is, smaller than the charge of the electron). [source:wikipedia]</skos:definition>
        <skos:prefLabel xml:lang="en">PartialChargeDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000122 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000122">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electronegativity descriptor</rdfs:label>
        <skos:definition xml:lang="en">An electronegativity descriptor is a chemical descriptor that is about the electronegativity quality of an atom.</skos:definition>
        <skos:prefLabel xml:lang="en">ElectronegativityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000123 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000123">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">chemical descriptor</rdfs:label>
        <skos:definition xml:lang="en">A chemical descriptor is a data item (quantity or value) about a chemical entity that conforms to a specification for how it is calculated, measured or recorded.</skos:definition>
        <skos:prefLabel xml:lang="en">ChemicalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000130 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000130">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:label xml:lang="en">bond multiplicity descriptor</rdfs:label>
        <skos:definition xml:lang="en">A bond multiplicity descriptor is a chemical descriptor that in primitive cases is defined as half of the difference between the number of bonding and antibonding electrons in a particular system, but may also be defined with relation to the strength of a single bond.</skos:definition>
        <skos:prefLabel xml:lang="en">BondMultiplicityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000131 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000131">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">charge descriptor</rdfs:label>
        <skos:definition xml:lang="en">A charge descriptor is a chemical descriptor which indicates the charge of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">ChargeDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000132 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000132">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000060"/>
        <rdfs:label xml:lang="en">bond length descriptor</rdfs:label>
        <skos:definition xml:lang="en">A bond length descriptor is a dimensional extent descriptor which gives the measured or predicted (idealised) length of an atom to atom bond within a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">BondLengthDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000136 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000136">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000123"/>
        <skos:definition xml:lang="en">Constitutional descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">ConstitutionalDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000137 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000137">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <rdfs:label xml:lang="en">Wiener polarity number descriptor</rdfs:label>
        <skos:definition xml:lang="en">Half the sum of all the distance matrix entries with a value of 3</skos:definition>
        <skos:prefLabel xml:lang="en">WienerPolarityNumberDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000140 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000140">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000302"/>
        <skos:definition xml:lang="en">PubChem compound identifier (CID)</skos:definition>
        <skos:prefLabel xml:lang="en">PubChemCompoundIdentifier(CID)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000141 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000141">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000302"/>
        <skos:definition xml:lang="en">PubChem substance identifier (SID)</skos:definition>
        <skos:prefLabel xml:lang="en">PubChemSubstanceIdentifier(SID)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000146 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000146">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <skos:definition xml:lang="en">Topological surface area descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">TopologicalSurfaceAreaDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000149 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000149">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000018"/>
        <rdfs:label xml:lang="en">generic SMILES descriptor</rdfs:label>
        <skos:definition xml:lang="en">a generic SMILES descriptor is a SMILES descriptor that denotes only the labeled molecular graph (i.e. atoms and bonds, but no chiral or isotopic information).</skos:definition>
        <skos:prefLabel xml:lang="en">GenericSMILESDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000152 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000152">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000146"/>
        <skos:definition xml:lang="en">Topological polar surface area descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">TopologicalPolarSurfaceAreaDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000153 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000153">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">charge weighted partial negative surface area</rdfs:label>
        <skos:altLabel xml:lang="en">PNSA-3</skos:altLabel>
        <skos:definition xml:lang="en">charge weighted partial negative surface area</skos:definition>
        <skos:prefLabel xml:lang="en">ChargeWeightedPartialNegativeSurfaceArea</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000154 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000154">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">DPSA-1</rdfs:label>
        <skos:altLabel xml:lang="en">DPSA-1</skos:altLabel>
        <skos:definition xml:lang="en">difference of PPSA-1 and PNSA-1</skos:definition>
        <skos:prefLabel xml:lang="en">DPSAMinus1</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000155 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000155">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">DPSA-2</rdfs:label>
        <skos:altLabel xml:lang="en">DPSA-2</skos:altLabel>
        <skos:definition xml:lang="en">difference of FPSA-2 and PNSA-2</skos:definition>
        <skos:prefLabel xml:lang="en">DPSAMinus2</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000156 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000156">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">DPSA-3</rdfs:label>
        <skos:altLabel xml:lang="en">DPSA-3</skos:altLabel>
        <skos:definition xml:lang="en">difference of PPSA-3 and PNSA-3</skos:definition>
        <skos:prefLabel xml:lang="en">DPSAMinus3</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000157 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000157">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">FPSA-1</rdfs:label>
        <skos:altLabel xml:lang="en">FPSA-1</skos:altLabel>
        <skos:definition xml:lang="en">PPSA-1 / total molecular surface area</skos:definition>
        <skos:prefLabel xml:lang="en">FPSAMinus1</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000158 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000158">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">FPSA-2</rdfs:label>
        <skos:altLabel xml:lang="en">FPSA-2</skos:altLabel>
        <skos:definition xml:lang="en">PPSA-2 / total molecular surface area</skos:definition>
        <skos:prefLabel xml:lang="en">FPSAMinus2</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000159 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000159">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">FPSA-3</rdfs:label>
        <skos:altLabel xml:lang="en">FPSA-3</skos:altLabel>
        <skos:definition xml:lang="en">PPSA-3 / total molecular surface area</skos:definition>
        <skos:prefLabel xml:lang="en">FPSAMinus3</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000160 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000160">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">FNSA-1</rdfs:label>
        <skos:altLabel xml:lang="en">FNSA-1</skos:altLabel>
        <skos:definition xml:lang="en">PNSA-1 / total molecular surface area</skos:definition>
        <skos:prefLabel xml:lang="en">FNSAMinus1</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000161 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000161">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">FNSA-2</rdfs:label>
        <skos:altLabel xml:lang="en">FNSA-2</skos:altLabel>
        <skos:definition xml:lang="en">PNSA-2 / total molecular surface area</skos:definition>
        <skos:prefLabel xml:lang="en">FNSAMinus2</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000162 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000162">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">FNSA-3</rdfs:label>
        <skos:altLabel xml:lang="en">FNSA-3</skos:altLabel>
        <skos:definition xml:lang="en">PNSA-3 / total molecular surface area</skos:definition>
        <skos:prefLabel xml:lang="en">FNSAMinus3</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000163 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000163">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">WPSA-1</rdfs:label>
        <skos:altLabel xml:lang="en">WPSA-1</skos:altLabel>
        <skos:definition xml:lang="en">PPSA-1 * total molecular surface area / 1000</skos:definition>
        <skos:prefLabel xml:lang="en">WPSAMinus1</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000164 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000164">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">WPSA-2</rdfs:label>
        <skos:altLabel xml:lang="en">WPSA-2</skos:altLabel>
        <skos:definition xml:lang="en">PPSA-2 * total molecular surface area /1000</skos:definition>
        <skos:prefLabel xml:lang="en">WPSAMinus2</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000165 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000165">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">WPSA-3</rdfs:label>
        <skos:altLabel xml:lang="en">WPSA-3</skos:altLabel>
        <skos:definition xml:lang="en">PPSA-3 * total molecular surface area /1000</skos:definition>
        <skos:prefLabel xml:lang="en">WPSAMinus3</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000166 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000166">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">WNSA-1</rdfs:label>
        <skos:altLabel xml:lang="en">WNSA-1</skos:altLabel>
        <skos:definition xml:lang="en">PNSA-1 * total molecular surface area /1000</skos:definition>
        <skos:prefLabel xml:lang="en">WNSAMinus1</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000167 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000167">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">WNSA-2</rdfs:label>
        <skos:altLabel xml:lang="en">WNSA-2</skos:altLabel>
        <skos:definition xml:lang="en">PNSA-2 * total molecular surface area /1000</skos:definition>
        <skos:prefLabel xml:lang="en">WNSAMinus2</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000168 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000168">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">WNSA-3</rdfs:label>
        <skos:altLabel xml:lang="en">WNSA-3</skos:altLabel>
        <skos:definition xml:lang="en">PNSA-3 * total molecular surface area /1000</skos:definition>
        <skos:prefLabel xml:lang="en">WNSAMinus3</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000169 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000169">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">relative positive charge</rdfs:label>
        <skos:altLabel xml:lang="en">RPCG</skos:altLabel>
        <skos:definition xml:lang="en">most positive charge / total positive charge</skos:definition>
        <skos:prefLabel xml:lang="en">RelativePositiveCharge</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000170 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000170">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">relative negative charge</rdfs:label>
        <skos:altLabel xml:lang="en">RNCG</skos:altLabel>
        <skos:definition xml:lang="en">most negative charge / total negative charge</skos:definition>
        <skos:prefLabel xml:lang="en">RelativeNegativeCharge</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000171 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000171">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">relative positive charge surface area</rdfs:label>
        <skos:altLabel xml:lang="en">RPCS</skos:altLabel>
        <skos:definition xml:lang="en">most positive surface area * RPCG</skos:definition>
        <skos:prefLabel xml:lang="en">RelativePositiveChargeSurfaceArea</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000172 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000172">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">relative negative charge surface area</rdfs:label>
        <skos:altLabel xml:lang="en">RNCS</skos:altLabel>
        <skos:definition xml:lang="en">most negative surface area * RNCG</skos:definition>
        <skos:prefLabel xml:lang="en">RelativeNegativeChargeSurfaceArea</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000173 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000173">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">THSA</rdfs:label>
        <skos:definition xml:lang="en">sum of solvent accessible surface areas of atoms with absolute value of partial charges less than 0.2</skos:definition>
        <skos:prefLabel xml:lang="en">THSA</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000174 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000174">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">TPSA</rdfs:label>
        <skos:definition xml:lang="en">sum of solvent accessible surface areas of atoms with absolute value of partial charges greater than or equal 0.2</skos:definition>
        <skos:prefLabel xml:lang="en">TPSA</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000175 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000175">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">RHSA</rdfs:label>
        <skos:definition xml:lang="en">THSA / total molecular surface area</skos:definition>
        <skos:prefLabel xml:lang="en">RHSA</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000176 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000176">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000229"/>
        <rdfs:label xml:lang="en">RPSA</rdfs:label>
        <skos:definition xml:lang="en">TPSA / total molecular surface area</skos:definition>
        <skos:prefLabel xml:lang="en">RPSA</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000177 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000177">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <skos:definition xml:lang="en">Collection of 3D coordinates</skos:definition>
        <skos:prefLabel xml:lang="en">CollectionOf3DCoordinates</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000178 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000178">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000177"/>
        <skos:definition xml:lang="en">Collection of 3D atomic coordinates</skos:definition>
        <skos:prefLabel xml:lang="en">CollectionOf3DAtomicCoordinates</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000179 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000179">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000094"/>
        <rdfs:label xml:lang="en">molecular polarizability</rdfs:label>
        <skos:altLabel xml:lang="en">BPol</skos:altLabel>
        <skos:definition xml:lang="en">Sum of the absolute value of the difference between atomic polarizabilities of all bonded atoms in the molecule (including implicit hydrogens)</skos:definition>
        <skos:prefLabel xml:lang="en">MolecularPolarizability</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000180 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000180">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000219"/>
        <rdfs:label xml:lang="en">fragment complexity descriptor</rdfs:label>
        <skos:altLabel xml:lang="en">FragmentComplexity</skos:altLabel>
        <skos:definition xml:lang="en">defined as @cdk.cite{Nilakantan06}</skos:definition>
        <skos:prefLabel xml:lang="en">FragmentComplexityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000181 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000181">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000093"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Vertex adjacency matrix descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">VertexAdjacencyMatrixDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000182 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000182">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000185"/>
        <rdfs:label xml:lang="en">Petitjean Topological Shape Index</rdfs:label>
        <skos:definition xml:lang="en">A measure of the anisotropy in a molecule (as per Petitjean et al)</skos:definition>
        <skos:prefLabel xml:lang="en">PetitjeanTopologicalShapeIndex</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000183 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000183">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000185"/>
        <rdfs:label xml:lang="en">Petitjean Geometric Shape Index</rdfs:label>
        <skos:definition xml:lang="en">A measure of the anisotropy in a molecule (as per Bath et al)</skos:definition>
        <skos:prefLabel xml:lang="en">PetitjeanGeometricShapeIndex</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000184 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000184">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <rdfs:label xml:lang="en">Petitjean number</rdfs:label>
        <skos:altLabel xml:lang="en">petitjeanNumber</skos:altLabel>
        <skos:definition xml:lang="en">the eccentricity of a vertex corresponds to the distance from that vertex to the most remote vertex in the graph. The distance is obtained from the distance matrix as the count of edges between the two vertices. If r i is the largest matrix entry in row i of the distance matrix D, then the radius is defined as the smallest of the r i . The graph diameter D is defined as the largest vertex eccentricity in the graph. Petitjean Number is the value of ( diameter - radius ) diameter .</skos:definition>
        <skos:prefLabel xml:lang="en">PetitjeanNumber</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000185 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000185">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <rdfs:label xml:lang="en">Petitjean Shape Index</rdfs:label>
        <skos:altLabel xml:lang="en">petitjeanShapeIndex</skos:altLabel>
        <skos:definition xml:lang="en">A measure of the anisotropy in a molecule</skos:definition>
        <skos:prefLabel xml:lang="en">PetitjeanShapeIndex</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000186 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000186">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000251"/>
        <rdfs:label xml:lang="en">XLogP descriptor</rdfs:label>
        <skos:altLabel xml:lang="en">XLogP</skos:altLabel>
        <skos:definition xml:lang="en">A LogP descriptor based on the atom-type method described in Wang, R., Fu, Y., and Lai, L.. A New Atom-Additive Method for Calculating Partition Coefficients, Journal of Chemical Information and Computer Sciences. vol. 37. 1997, pp. 615-621.</skos:definition>
        <skos:prefLabel xml:lang="en">XLogPDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000187 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000187">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000251"/>
        <rdfs:label xml:lang="en">MLogP descriptor</rdfs:label>
        <skos:altLabel xml:lang="en">MannholdLogP</skos:altLabel>
        <skos:definition xml:lang="en">A LogP descriptor based on a simple equation using the number of carbons and hetero atoms.</skos:definition>
        <skos:prefLabel xml:lang="en">MLogPDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000188 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000188">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000189"/>
        <skos:definition xml:lang="en">Maximal ratio of length to breadth descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">MaximalRatioOfLengthToBreadthDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000189 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000189">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000093"/>
        <obo:IAO_0000115>A descriptor characterizing the ratio of the length to the breadth of a given entity.</obo:IAO_0000115>
        <skos:definition xml:lang="en">Ratio of length to breadth descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">RatioOfLengthToBreadthDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000190 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000190">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000189"/>
        <skos:definition xml:lang="en">Minimal ratio of length to breadth descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">MinimalRatioOfLengthToBreadthDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000191 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000191">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000094"/>
        <obo:IAO_0000115>An ionization energy descriptor is a descriptor that describes the minimum amount of energy required to remove an electron (to an infinite distance) from an atom or molecule in a gaseous state. 

X + energy → X+ + e-

The term &apos;ionization potential&apos; has historically been used but is now no longer recommended. </obo:IAO_0000115>
        <obo:IAO_0000118>ionization energy</obo:IAO_0000118>
        <obo:IAO_0000118>ionization enthalpy</obo:IAO_0000118>
        <obo:IAO_0000118>ionization potential</obo:IAO_0000118>
        <skos:definition xml:lang="en">Ionization energy descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">IonizationEnergyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000192 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000192">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <skos:altLabel xml:lang="en">EccentricConnectivityIndex</skos:altLabel>
        <skos:definition xml:lang="en">Eccentric connectivity index descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">EccentricConnectivityIndexDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000193 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000193">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <skos:definition xml:lang="en">Equilibrium constant</skos:definition>
        <skos:prefLabel xml:lang="en">EquilibriumConstant</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000194 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000194">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000193"/>
        <rdfs:label xml:lang="en">acid dissociation constant</rdfs:label>
        <skos:altLabel xml:lang="en">Ka</skos:altLabel>
        <skos:definition xml:lang="en">the acid dissociation constant, Ka, is quantitative measure of the strength of an acid in solution. It is the equilibrium constant for a chemical reaction known as dissociation in the context of acid-base reactions.</skos:definition>
        <skos:prefLabel xml:lang="en">AcidDissociationConstant</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000195 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000195">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000193"/>
        <rdfs:label xml:lang="en">pKa</rdfs:label>
        <skos:altLabel xml:lang="en">pKa</skos:altLabel>
        <skos:definition xml:lang="en">the logarithmic measure of the acid dissociation constant (Ka)</skos:definition>
        <skos:prefLabel xml:lang="en">PKa</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000198 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000198">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000216"/>
        <obo:IAO_0000115>A molecular weight descriptor calculated by a relevant module of the Pipeline Pilot software tool. </obo:IAO_0000115>
        <skos:definition xml:lang="en">Molecular weight calculated by pipeline pilot</skos:definition>
        <skos:prefLabel xml:lang="en">MolecularWeightCalculatedByPipelinePilot</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000199 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000199">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000032"/>
        <rdfs:label xml:lang="en">absolute SMILES descriptor</rdfs:label>
        <skos:definition xml:lang="en">An absolute SMILES descriptor is an isomeric SMILES descriptor that is produced using a canonicalization algorithm. </skos:definition>
        <skos:prefLabel xml:lang="en">AbsoluteSMILESDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000202 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000202">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:label xml:lang="en">tautomer count</rdfs:label>
        <skos:definition xml:lang="en">a count descriptor that denotes the number of tautomers.</skos:definition>
        <skos:prefLabel xml:lang="en">TautomerCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000203 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000203">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <skos:definition xml:lang="en">Stereocenter count</skos:definition>
        <skos:prefLabel xml:lang="en">StereocenterCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000205 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000205">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000203"/>
        <owl:disjointWith rdf:resource="http://semanticscience.org/resource/CHEMINF_000213"/>
        <skos:definition xml:lang="en">Atom stereocenter count</skos:definition>
        <skos:prefLabel xml:lang="en">AtomStereocenterCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000206 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000206">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000205"/>
        <skos:definition xml:lang="en">Defined atom stereocenter count</skos:definition>
        <skos:prefLabel xml:lang="en">DefinedAtomStereocenterCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000207 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000207">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000016"/>
        <rdfs:label xml:lang="en">formation energy descriptor</rdfs:label>
        <skos:definition xml:lang="en">A formation energy descriptor is an energetic descriptor which gives the value for the energy of formation of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">FormationEnergyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000208 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000208">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000016"/>
        <rdfs:label xml:lang="en">solvation energy descriptor</rdfs:label>
        <skos:definition xml:lang="en">A solvation energy descriptor is a chemical descriptor which gives the value for the energy of dissolving a particular chemical entity in a solvent.</skos:definition>
        <skos:prefLabel xml:lang="en">SolvationEnergyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000209 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000209">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000136"/>
        <rdfs:label xml:lang="en">count descriptor</rdfs:label>
        <skos:definition xml:lang="en">A count descriptor is a chemical descriptor which is calculated by counting the number of features of a certain kind which are present in the chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">CountDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000210 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000210">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000016"/>
        <rdfs:label xml:lang="en">dissociation energy descriptor</rdfs:label>
        <skos:definition xml:lang="en">A dissociation energy descriptor is an energetic descriptor which gives a value for the dissociation energy for a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">DissociationEnergyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000212 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000212">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000205"/>
        <skos:definition xml:lang="en">Undefined atom stereocenter count</skos:definition>
        <skos:prefLabel xml:lang="en">UndefinedAtomStereocenterCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000213 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000213">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000203"/>
        <skos:definition xml:lang="en">Bond stereocenter count</skos:definition>
        <skos:prefLabel xml:lang="en">BondStereocenterCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000214 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000214">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000213"/>
        <skos:definition xml:lang="en">Defined bond stereocenter count</skos:definition>
        <skos:prefLabel xml:lang="en">DefinedBondStereocenterCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000215 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000215">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000213"/>
        <skos:definition xml:lang="en">Undefined bond stereocenter count</skos:definition>
        <skos:prefLabel xml:lang="en">UndefinedBondStereocenterCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000216 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000216">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000088"/>
        <rdfs:label xml:lang="en">average molecular weight descriptor</rdfs:label>
        <skos:definition xml:lang="en">The mass of a molecule calculated using the average mass of each element weighted for its natural isotopic abundance. E.g., Carbon has two natural isotopes 12 and 13 with relative abundances of 98.9% and 1.1% to yield an average mass of 12.011 g/mol</skos:definition>
        <skos:prefLabel xml:lang="en">AverageMolecularWeightDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000217 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000217">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000088"/>
        <rdfs:label xml:lang="en">exact mass descriptor</rdfs:label>
        <skos:definition xml:lang="en">an exact mass descriptor corresponds to the mass of the most intense molecule/ion peak in an MS spec, and when calculated denotes the mass of an ion or a molecule containing most likely isotopic composition for a single random molecule.</skos:definition>
        <skos:prefLabel xml:lang="en">ExactMassDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000218 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000218">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000088"/>
        <rdfs:label xml:lang="en">monoisotopic mass descriptor</rdfs:label>
        <skos:definition xml:lang="en">The mass of a molecule calculated using the mass of the most abundant isotope of each element. E.g., Carbon has a monoisotopic mass of 12.000 g/mol.</skos:definition>
        <skos:prefLabel xml:lang="en">MonoisotopicMassDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000219 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000219">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000085"/>
        <rdfs:label xml:lang="en">complexity descriptor</rdfs:label>
        <skos:definition xml:lang="en">A complexity descriptor denotes the how complicated a structure is, seen from both the point of view of the elements contained and its structural features .</skos:definition>
        <skos:prefLabel xml:lang="en">ComplexityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000223 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000223">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pi-system size</rdfs:label>
        <skos:altLabel xml:lang="en">LargestPiSystem</skos:altLabel>
        <skos:definition xml:lang="en">The integer number of atoms in a pi-orbital system.</skos:definition>
        <skos:prefLabel xml:lang="en">PiMinussystemSize</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000224 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000224">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000210"/>
        <rdfs:label xml:lang="en">bond dissociation Gibbs energy descriptor</rdfs:label>
        <skos:definition xml:lang="en">Bond dissociation Gibbs energy descriptor captures the Gibbs energy associated with the process of breaking the bond in question. This could be measured or calculated in vacuo or in a specific Solvent, at a given temperature and pressure. Depends on molecular conformation.</skos:definition>
        <skos:prefLabel xml:lang="en">BondDissociationGibbsEnergyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000225 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000225">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000208"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">solvation Gibbs energy descriptor</rdfs:label>
        <skos:definition xml:lang="en">The molecular entity solvation Gibbs energy descriptor reflects the Gibbs energy associated with the solvation of the molecular entity in question. This could be measured or calculated in vacuo or in a specific solvent, at a particular temperature and pressure. Depends on molecular conformation when computed.</skos:definition>
        <skos:prefLabel xml:lang="en">SolvationGibbsEnergyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000226 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000226">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000231"/>
        <skos:definition xml:lang="en">Bond charge density descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">BondChargeDensityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000229 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000229">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000060"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">surface area descriptor</rdfs:label>
        <skos:definition xml:lang="en">A surface area descriptor is a descriptor which describes a measure or calculation of the surface area of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">SurfaceAreaDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000231 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000231">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">charge density descriptor</rdfs:label>
        <skos:definition xml:lang="en">A charge density descriptor is a chemical entity descriptor which indicates the distribution of the electric charge over the volume of the chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">ChargeDensityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000232 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000232">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000263"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aromatic atom count</rdfs:label>
        <skos:definition xml:lang="en">A descriptor that provides the integer count of aromatic atoms in a given molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">AromaticAtomCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000233 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000233">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bond count</rdfs:label>
        <skos:definition xml:lang="en">A descriptor that specifies the integer count of bonds in a given molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">BondCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000234 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000234">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000140"/>
        <skos:definition xml:lang="en">PubChem conformer identifier</skos:definition>
        <skos:prefLabel xml:lang="en">PubChemConformerIdentifier</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000237 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000237">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000056"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bond aromaticity descriptor</rdfs:label>
        <skos:definition xml:lang="en">A bond aromaticity descriptor is an aromaticity descriptor associated with a bond within a chemical entity which indicates whether that  bond belongs to an aromatic system.</skos:definition>
        <skos:prefLabel xml:lang="en">BondAromaticityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000239 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000239">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000207"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">formation Gibbs energy descriptor</rdfs:label>
        <skos:definition xml:lang="en">The formation Gibbs energy descriptor captures the Gibbs energy associated with the formation of a molecular entity, relative to the standard state of constituent atoms. This can be measured, calculated in vacuo, or calculated with respect to a specific solvent, at a particular temperature and pressure. When calculated, the formation Gibbs energy value depends on the molecular conformation.</skos:definition>
        <skos:prefLabel xml:lang="en">FormationGibbsEnergyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000240 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000240">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000246"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">size of largest aliphatic chain</rdfs:label>
        <skos:definition xml:lang="en">The largest aliphatic chain size descriptor is a count descriptor that gives the integer length (number of atoms) in the largest unbranched chain of atoms that does not contain aromatic atoms, within a given molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">SizeOfLargestAliphaticChain</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000241 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000241">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000207"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000118>enthalpy of formation</obo:IAO_0000118>
        <obo:IAO_0000118>heat of formation</obo:IAO_0000118>
        <rdfs:label xml:lang="en">formation enthalpy descriptor</rdfs:label>
        <skos:definition xml:lang="en">Molecular entity formation enthaply descriptor captures the enthalpy associated with the formation of the molecular entity in question, relative to the standard state of constituent atoms. This could be measured or calculated in vacuo or in a specific Solvent, at a particular temperature and pressure. Depends on molecular conformation when computed.</skos:definition>
        <skos:prefLabel xml:lang="en">FormationEnthalpyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000242 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000242">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000060"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">volume descriptor</rdfs:label>
        <skos:definition xml:lang="en">A volume descriptor is a descriptor which describes a measure or calculation of the volume of a chemical entity.</skos:definition>
        <skos:prefLabel xml:lang="en">VolumeDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000243 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000243">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000233"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">aromatic bond count</rdfs:label>
        <skos:definition xml:lang="en">A descriptor that provides the integer count of aromatic bonds in a given molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">AromaticBondCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000244 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000244">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">hydrogen bond donor count</rdfs:label>
        <skos:definition xml:lang="en">A descriptor that reflects the integer number of hydrogen bond donors in a given molecular entity, as determined by a given method. In highly simplified terms, this is usually the count of all negatively or partially negatively charged heteroatoms (e.g. alcohol oxygen) that have covalently attached to them partially positively charged hydrogen atoms that are capable of participating in a hydrogen bond.</skos:definition>
        <skos:prefLabel xml:lang="en">HydrogenBondDonorCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000245 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000245">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">hydrogen bond acceptor count</rdfs:label>
        <skos:definition xml:lang="en">A descriptor that reflects the integer number of hydrogen bond acceptors in a given molecular entity, as determined by a given method. In highly simplified terms, this is usually the count of all negatively or partially negatively charged heteroatoms (e.g. alcohol oxygen) capable of accepting a hydrogen bond.</skos:definition>
        <skos:prefLabel xml:lang="en">HydrogenBondAcceptorCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000246 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000246">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">size of largest chain</rdfs:label>
        <skos:definition xml:lang="en">The largest chain size descriptor is a count descriptor that gives the integer length (number of atoms) in the largest chain in a molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">SizeOfLargestChain</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000249 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000249">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000208"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">solvation entropy descriptor</rdfs:label>
        <skos:definition xml:lang="en">The molecular entity solvation entropy descriptor reflects the entropy associated with the solvation of the molecular entity in question. This could be measured or calculated in vacuo or in a specific solvent, at a particular temperature and pressure. Depends on molecular conformation when computed.</skos:definition>
        <skos:prefLabel xml:lang="en">SolvationEntropyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000250 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000250">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000208"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">solvation enthalpy descriptor</rdfs:label>
        <skos:definition xml:lang="en">The molecular entity solvation enthalpy descriptor reflects the enthalpy associated with the solvation of the molecular entity in question. This could be measured or calculated in vacuo or in a specific solvent, at a particular temperature and pressure. Depends on molecular conformation when computed.</skos:definition>
        <skos:prefLabel xml:lang="en">SolvationEnthalpyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000251 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000251">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">logP descriptor</rdfs:label>
        <skos:definition xml:lang="en">The logarithm of octanol-water partition coefficient, which is the ratio of the molecules dissolved in octanol to those dissolved in pure un-ionized water upon mixture equilibration. This can be measured or predicted. The value is dimensionless. May depend on molecular conformation when computed.</skos:definition>
        <skos:prefLabel xml:lang="en">LogPDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000252 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000252">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000210"/>
        <rdfs:label xml:lang="en">bond dissociation enthalpy descriptor</rdfs:label>
        <skos:definition xml:lang="en">Bond dissociation enthalpy descriptor captures the enthalpy associated with the process of breaking the bond in question. This could be measured or calculated in vacuo or in a specific Solvent, at a given temperature and pressure. Depends on molecular conformation.</skos:definition>
        <skos:prefLabel xml:lang="en">BondDissociationEnthalpyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000253 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000253">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">refractive index descriptor</rdfs:label>
        <skos:definition xml:lang="en">Chemical substance refractive index descriptor is a unitless descriptor that specifies the ratio of the speed of light in vacuum to that in a given chemical substance. [IUPAC: http://goldbook.iupac.org/R05240.html]</skos:definition>
        <skos:prefLabel xml:lang="en">RefractiveIndexDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000254 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000254">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000233"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">rotatable bond count</rdfs:label>
        <skos:altLabel xml:lang="en">RotatableBondsCount</skos:altLabel>
        <skos:definition xml:lang="en">a bond count that denotes the integer number of rotors in the molecule, generally single bonds torsion around which produces non-identical geometric molecular configurations.</skos:definition>
        <skos:prefLabel xml:lang="en">RotatableBondCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000256 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000256">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Melting point descriptor</skos:definition>
        <skos:definition xml:lang="en">Melting point descriptor specifies the temperature at which a chemical substance undergoes the transition from solid to liquid state under standard conditions.</skos:definition>
        <skos:prefLabel xml:lang="en">MeltingPointDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000257 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000257">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Boiling point descriptor</skos:definition>
        <skos:definition xml:lang="en">The boiling point descriptor indicates the temperature at which a chemical substance undergoes a state transition from liquid to gas, at standard conditions.</skos:definition>
        <skos:prefLabel xml:lang="en">BoilingPointDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000260 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000260">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000207"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">formation entropy descriptor</rdfs:label>
        <skos:definition xml:lang="en">Molecular entity formaiton entropy descriptor captures the entropy associated with the formation of the molecular entity in question, relative to the standard state of constituent atoms. This could be measured or calculated in vacuo or in a specific Solvent, at a particular temperature and pressure. Depends on molecular conformation when computed.</skos:definition>
        <skos:prefLabel xml:lang="en">FormationEntropyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000261 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000261">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://semanticscience.org/resource/CHEMINF_000266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">relative permittivity descriptor</rdfs:label>
        <skos:definition xml:lang="en">The relative permittivity descriptor specifies the ratio of the electric field strength in vacuum to that in a given medium. It was formerly called the dielectric constant. [IUPAC Gold Book: http://goldbook.iupac.org/R05273.html ]</skos:definition>
        <skos:prefLabel xml:lang="en">RelativePermittivityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000263 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000263">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://semanticscience.org/resource/CHEMINF_000012"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">atom count</rdfs:label>
        <skos:definition xml:lang="en">A descriptor that specifies the integer count of atoms in a given molecular entity.</skos:definition>
        <skos:prefLabel xml:lang="en">AtomCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000264 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000264">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000231"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:definition xml:lang="en">Atomic charge density descriptor</skos:definition>
        <skos:prefLabel xml:lang="en">AtomicChargeDensityDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000265 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000265">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000210"/>
        <rdfs:label xml:lang="en">bond dissociation entropy descriptor</rdfs:label>
        <skos:definition xml:lang="en">Bond dissociation entropy descriptor captures the entropy associated with the process of breaking the bond in question. This could be measured or calculated in vacuo or in a specific Solvent, at a given temperature and pressure. Depends on molecular conformation.</skos:definition>
        <skos:prefLabel xml:lang="en">BondDissociationEntropyDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000266 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000266">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000000"/>
        <skos:definition xml:lang="en">Chemical substance</skos:definition>
        <skos:definition xml:lang="en">Chemical substance constitutes matter of constant composition, that may contain a collection of molecular entities. [IUPAC: http://goldbook.iupac.org/C01039.html]</skos:definition>
        <skos:prefLabel xml:lang="en">ChemicalSubstance</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000267 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000267">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000209"/>
        <rdfs:label xml:lang="en">effective rotor count</rdfs:label>
        <skos:definition xml:lang="en">A count descriptor that takes into account flexibility of rings and rotatable bonds.</skos:definition>
        <skos:prefLabel xml:lang="en">EffectiveRotorCount</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000268 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000268">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000131"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">total formal charge descriptor</rdfs:label>
        <skos:definition xml:lang="en">A charge descriptor that gives the total charge for a molecule</skos:definition>
        <skos:prefLabel xml:lang="en">TotalFormalChargeDescriptor</skos:prefLabel>
    </owl:Class>
    


