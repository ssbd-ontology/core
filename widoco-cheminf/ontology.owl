    <!-- http://semanticscience.org/resource/CHEMINF_000807 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000807">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000216"/>
        <skos:definition xml:lang="en">Average molecular weight calculated by RDKit software library version 2015_09_2</skos:definition>
        <skos:prefLabel xml:lang="en">AverageMolecularWeightCalculatedByRDKitSoftwareLibraryVersion2015092</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000808 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_000808">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000307"/>
        <skos:definition xml:lang="en">Total polar surface area calculated by RDKit software library version 2015_09_2</skos:definition>
        <skos:prefLabel xml:lang="en">TotalPolarSurfaceAreaCalculatedByRDKitSoftwareLibraryVersion2015092</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001100 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001100">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_23367"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">Bond Polarizabilities</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates the sum of the absolute value of the difference between atomic polarizabilities of all bonded atoms in the molecule (including implicit hydrogens).</skos:definition>
        <skos:prefLabel xml:lang="en">BondPolarizabilities</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001101 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001101">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <rdfs:subClassOf rdf:resource="http://www.blueobelisk.org/ontologies/chemoinformatics-algorithms/#AtomicDescriptor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_33250"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>https://doi.org/10.1351/goldbook.O04365</terms:source>
        <rdfs:label xml:lang="en">oxidation state</rdfs:label>
        <skos:definition xml:lang="en">Oxidation state is an atomic descriptor that gives the degree of oxidation of an atom in terms of counting electrons. The higher the oxidation state (OS) of a given atom, the greater is its degree of oxidation. [source: IUPAC Gold Book - https://doi.org/10.1351/goldbook.O04365]</skos:definition>
        <skos:prefLabel xml:lang="en">OxidationState</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001104 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001104">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000018"/>
        <rdfs:label xml:lang="en">connectivity SMILES descriptor</rdfs:label>
        <skos:definition xml:lang="en">A connectivity SMILES descriptor is a SMILES descriptor that does not include any stereochemical or isotopic information.</skos:definition>
        <skos:prefLabel xml:lang="en">ConnectivitySMILESDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001500 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001500">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <bibo:doi> http://dx.doi.org/10.1021/ci980137x</bibo:doi>
        <cheminf:short_name>BCUT</cheminf:short_name>
        <rdfs:label xml:lang="en">BCUT</rdfs:label>
        <skos:definition xml:lang="en">Eigenvalue based descriptor noted for its utility in chemical diversity.</skos:definition>
        <skos:prefLabel xml:lang="en">BCUT</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001501 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001501">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <cheminf:short_name>bondPartialPiCharge</cheminf:short_name>
        <rdfs:label xml:lang="en">bond partial pi charge</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates bond-pi Partial charge of a bond by determining the difference the Partial Pi Charge on atoms A and B of a bond (based in Gasteiger Charge).</skos:definition>
        <skos:prefLabel xml:lang="en">BondPartialPiCharge</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001502 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001502">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <cheminf:short_name>bondPartialSigmaCharge</cheminf:short_name>
        <rdfs:label xml:lang="en">bond partial sigma charge</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates bond-sigma Partial charge of a bond.</skos:definition>
        <skos:prefLabel xml:lang="en">BondPartialSigmaCharge</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001503 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001503">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <cheminf:short_name>bondPartialTCharge</cheminf:short_name>
        <rdfs:label xml:lang="en">bond partial total charge</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates bond-total Partial charge of a bond.</skos:definition>
        <skos:prefLabel xml:lang="en">BondPartialTotalCharge</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001504 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001504">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <cheminf:short_name>bondSigmaElectronegativity</cheminf:short_name>
        <rdfs:label xml:lang="en">bond sigma electronegativity</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates of bond-Polarizability of a bond by determining the difference the Sigma electronegativity on atoms A and B of a bond.</skos:definition>
        <skos:prefLabel xml:lang="en">BondSigmaElectronegativity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001505 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001505">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <cheminf:short_name>bondsToAtom</cheminf:short_name>
        <rdfs:comment xml:lang="en">This is the shortest distance between a pair of atoms in a graph, defined as the number of edges in the shortest path between the atom pair in the molecular graph.</rdfs:comment>
        <rdfs:label xml:lang="en">bonds to Atom</rdfs:label>
        <skos:definition xml:lang="en">Descriptor based on the number of bonds on the shortest path between two atoms (topological distance).</skos:definition>
        <skos:prefLabel xml:lang="en">BondsToAtom</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001506 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001506">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <cheminf:short_name>chiChain</cheminf:short_name>
        <rdfs:comment xml:lang="en">It utilizes the graph isomorphism code of the CDK to find fragments matching SMILES strings representing the fragments corresponding to each type of chain.</rdfs:comment>
        <rdfs:label xml:lang="en">chi chain indices</rdfs:label>
        <skos:definition xml:lang="en">Evluates the simple and valence chi chain descriptors (Kier and Hall) of orders 3, 4, 5, 6 and 7. </skos:definition>
        <skos:prefLabel xml:lang="en">ChiChainIndices</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001507 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001507">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <cheminf:short_name>chiCluster</cheminf:short_name>
        <rdfs:comment xml:lang="en"> It utilizes the graph isomorphism code of the CDK to find fragments matching SMILES strings representing the fragments corresponding to each type of chain.</rdfs:comment>
        <rdfs:label xml:lang="en">chi cluster indices</rdfs:label>
        <skos:definition xml:lang="en">Evluates the simple and valence chi cluster descriptors (Kier and Hall) of orders 3, 4,5 and 6.</skos:definition>
        <skos:prefLabel xml:lang="en">ChiClusterIndices</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001508 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001508">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <cheminf:short_name>chiPath</cheminf:short_name>
        <rdfs:comment xml:lang="en">It utilizes the graph isomorphism code of the CDK to find fragments matching SMILES strings representing the fragments corresponding to each type of chain.</rdfs:comment>
        <rdfs:label xml:lang="en">chi path indices</rdfs:label>
        <skos:definition xml:lang="en">Evaluates the Kier and Hall Chi path indices of orders 0,1,2,3,4,5,6 and 7.  </skos:definition>
        <skos:prefLabel xml:lang="en">ChiPathIndices</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001509 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001509">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <cheminf:short_name>chiPathCluster</cheminf:short_name>
        <rdfs:comment xml:lang="en">It utilizes the graph isomorphism code of the CDK to find fragments matching SMILES strings representing the fragments corresponding to each type of chain.</rdfs:comment>
        <rdfs:label xml:lang="en">chi path-cluster indices</rdfs:label>
        <skos:definition xml:lang="en">Evaluates the Kier and Hall Chi path cluster indices of orders 4,5 and 6.</skos:definition>
        <skos:prefLabel xml:lang="en">ChiPathMinusclusterIndices</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001510 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001510">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000093"/>
        <bibo:doi>http://dx.doi.org/10.1021/jp953224q</bibo:doi>
        <cheminf:short_name>gravitationalIndex</cheminf:short_name>
        <rdfs:label xml:lang="en">gravitational index</rdfs:label>
        <skos:definition xml:lang="en">Descriptor characterizing the mass distribution of the molecule.</skos:definition>
        <skos:prefLabel xml:lang="en">GravitationalIndex</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001511 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001511">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_001510"/>
        <bibo:doi>http://dx.doi.org/10.1021/ci980029a</bibo:doi>
        <cheminf:short_name>gravitationalIndex_SquareAndCubeRoots</cheminf:short_name>
        <rdfs:label xml:lang="en">gravitational index (square and cube roots)</rdfs:label>
        <skos:definition xml:lang="en">Descriptor characterizing the mass distribution of the molecule as the square or cube root of the gravitational index.</skos:definition>
        <skos:prefLabel xml:lang="en">GravitationalIndex(squareAndCubeRoots)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001512 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001512">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <bibo:doi>http://dx.doi.org/10.1021/jm011039x</bibo:doi>
        <cheminf:short_name>hBondAcceptorsBoehmKlebe</cheminf:short_name>
        <rdfs:label xml:lang="en">acceptor field atoms (Boehm,Klebe)</rdfs:label>
        <skos:definition xml:lang="en">Counts the number of acceptor field atoms for a carbonyl oxygen probe using force field based definition.</skos:definition>
        <skos:prefLabel xml:lang="en">AcceptorFieldAtoms(Boehm,Klebe)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001513 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001513">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <cheminf:short_name>hBondacceptorsDaylight</cheminf:short_name>
        <rdfs:comment xml:lang="en">SMILES on-line tutorial, http://www.daylight.com/dayhtml_tutorials/languages/smarts/smarts_examples.html)</rdfs:comment>
        <rdfs:label xml:lang="en">hydrogen bond acceptors (Daylight)</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates the number of hydrogen bond acceptors (by Daylight).</skos:definition>
        <skos:prefLabel xml:lang="en">HydrogenBondAcceptors(Daylight)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001514 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001514">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <bibo:doi>http://dx.doi.org/10.1021/jm011039x</bibo:doi>
        <cheminf:short_name>hBondAcceptorsDonorsBoehmKlebe</cheminf:short_name>
        <rdfs:label xml:lang="en">acceptors or donors field atoms (Boehm,Klebe)</rdfs:label>
        <skos:definition xml:lang="en">Counts the number of acceptor/donor field atoms for a carbonyl oxygen or amino hydrogen probe. </skos:definition>
        <skos:prefLabel xml:lang="en">AcceptorsOrDonorsFieldAtoms(Boehm,Klebe)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001515 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001515">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <bibo:doi>http://dx.doi.org/10.1021/jm011039x</bibo:doi>
        <cheminf:short_name>hBondDonorsBoehmKlebe</cheminf:short_name>
        <rdfs:label xml:lang="en">donor field atoms (Boehm,Klebe)</rdfs:label>
        <skos:definition xml:lang="en">Counts the number of donor field atoms for an amino hydrogen probe.</skos:definition>
        <skos:prefLabel xml:lang="en">DonorFieldAtoms(Boehm,Klebe)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001516 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001516">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <cheminf:short_name>hBondDonorsDaylight</cheminf:short_name>
        <rdfs:comment xml:lang="en">SMILES on-line tutorial, http://www.daylight.com/dayhtml_tutorials/languages/smarts/smarts_examples.html)</rdfs:comment>
        <rdfs:label xml:lang="en">hydrogen bond donors (Daylight)</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates the number of hydrogen bond donors (by Daylight).</skos:definition>
        <skos:prefLabel xml:lang="en">HydrogenBondDonors(Daylight)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001517 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001517">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000136"/>
        <cheminf:short_name>isProtonInAromaticSystem</cheminf:short_name>
        <rdfs:label xml:lang="en">proton belonging to an aromatic system</rdfs:label>
        <skos:definition xml:lang="en">Descriptor returns 1 if the protons is directly bonded to an aromatic system, it returns 2 if the distance between aromatic system and proton is 2 bonds, and it return 0 for other positions.</skos:definition>
        <skos:prefLabel xml:lang="en">ProtonBelongingToAnAromaticSystem</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001518 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001518">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000136"/>
        <cheminf:short_name>isProtonInConjugatedPiSystem</cheminf:short_name>
        <rdfs:label xml:lang="en">proton belonging to a pi-system</rdfs:label>
        <skos:definition xml:lang="en">Descriptor returns true if the protons is directly bonded to a pi system.</skos:definition>
        <skos:prefLabel xml:lang="en">ProtonBelongingToAPiMinussystem</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001519 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001519">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <bibo:doi>http://dx.doi.org/10.3390/91201004</bibo:doi>
        <cheminf:short_name>kierHallSmarts</cheminf:short_name>
        <rdfs:label xml:lang="en">Kier Hall SMARTS</rdfs:label>
        <skos:definition xml:lang="en">Counts the number of occurrences of the E-state fragments.</skos:definition>
        <skos:prefLabel xml:lang="en">KierHallSMARTS</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001520 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001520">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <bibo:doi>http://dx.doi.org/10.1021/ci970109z</bibo:doi>
        <cheminf:short_name>mde</cheminf:short_name>
        <rdfs:label xml:lang="en">molecular distance edge</rdfs:label>
        <skos:definition xml:lang="en">Evaluate molecular distance edge descriptors for C, N and O.</skos:definition>
        <skos:prefLabel xml:lang="en">MolecularDistanceEdge</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001521 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001521">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000093"/>
        <cheminf:short_name>momentOfInertia</cheminf:short_name>
        <rdfs:label xml:lang="en">moments of inertia</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates the principal moments of inertia and ratios of the principal moments. Als calculates the radius of gyration.</skos:definition>
        <skos:prefLabel xml:lang="en">MomentsOfInertia</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001522 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001522">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <cheminf:short_name>partialTChargeMMFF94</cheminf:short_name>
        <rdfs:label xml:lang="en">partial total charge (MMFF94)</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates total partial charges of an heavy atom.</skos:definition>
        <skos:prefLabel xml:lang="en">PartialTotalCharge(MMFF94)</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001523 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001523">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000136"/>
        <cheminf:short_name>period</cheminf:short_name>
        <rdfs:label xml:lang="en">period of an atom</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that returns the period in the periodic table of an atom belonging to an atom container.</skos:definition>
        <skos:prefLabel xml:lang="en">PeriodOfAnAtom</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001524 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001524">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000136"/>
        <cheminf:short_name>piContact</cheminf:short_name>
        <rdfs:label xml:lang="en">pi-contact of two atoms</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that check if two atoms have pi-contact (this is true when there is one and the same conjugated pi-system which contains both atoms, or directly linked neighboors of the atoms).</skos:definition>
        <skos:prefLabel xml:lang="en">PiMinuscontactOfTwoAtoms</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001525 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001525">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <cheminf:short_name>protonPartialCharge</cheminf:short_name>
        <rdfs:label xml:lang="en">proton total partial charge</rdfs:label>
        <skos:definition xml:lang="en">Descriptor that calculates partial charges of an heavy atom and its protons based on Gasteiger Marsili (PEOE).</skos:definition>
        <skos:prefLabel xml:lang="en">ProtonTotalPartialCharge</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001526 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001526">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <bibo:doi>http://dx.doi.org/10.1021/ac010737m</bibo:doi>
        <cheminf:short_name>rdfProtonCalculatedValues</cheminf:short_name>
        <rdfs:comment xml:lang="en">This is a mixed descriptor: topological, geometrical and electronic descriptor.</rdfs:comment>
        <rdfs:label xml:lang="en">RDF proton descriptor</rdfs:label>
        <skos:definition xml:lang="en">Calculation of RDF proton descriptor.</skos:definition>
        <skos:prefLabel xml:lang="en">RDFProtonDescriptor</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001527 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001527">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000087"/>
        <bibo:doi>http://dx.doi.org/10.1016/0097-8485(94)00052-G</bibo:doi>
        <cheminf:short_name>taeAminoAcid</cheminf:short_name>
        <rdfs:comment xml:lang="en">{@cdk.cite BREN1995} {@cdk.cite BREN1997} {@cdk.cite WHITE2003}</rdfs:comment>
        <rdfs:label xml:lang="en">TAE RECON descriptors for amino acid sequences</rdfs:label>
        <skos:definition xml:lang="en">Descriptors are derived from pre-calculated quantum mechanical parameters by using the paramaters for amino acids and evaluating a set of 147 descriptors for peptide sequences.</skos:definition>
        <skos:prefLabel xml:lang="en">TAERECONDescriptorsForAminoAcidSequences</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001528 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001528">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <cheminf:short_name>weightedPath</cheminf:short_name>
        <rdfs:label xml:lang="en">weighted path</rdfs:label>
        <skos:definition xml:lang="en">The weighted path (molecular ID) descriptors were described by Randic and they characterize molecular branching.</skos:definition>
        <skos:prefLabel xml:lang="en">WeightedPath</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001529 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001529">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <cheminf:short_name>WHIM</cheminf:short_name>
        <rdfs:comment xml:lang="en">Todeschini, R. and Gramatica, P.. New 3D Molecular Descriptors: The WHIM theory and QAR Applications, Persepectives in Drug Discovery and Design. 1998, pp. 355-380. Mixed descriptors: molecular size, shape, symmetry, and atom distribution and density. Uses 3D coordinates, PCA and it calculates 10 descriptors.</rdfs:comment>
        <rdfs:label xml:lang="en">WHIM</rdfs:label>
        <skos:definition xml:lang="en">Holistic descriptors described by Todeschini et al.</skos:definition>
        <skos:prefLabel xml:lang="en">WHIM</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_001530 -->


    <owl:Class rdf:about="http://semanticscience.org/resource/CHEMINF_001530">
        <rdfs:subClassOf rdf:resource="http://semanticscience.org/resource/CHEMINF_000092"/>
        <cheminf:short_name>autoCorrelationCharge</cheminf:short_name>
        <rdfs:comment xml:lang="en">ATSc1 - ATSc5</rdfs:comment>
        <rdfs:label xml:lang="en">Moreau-Broto Autocorrelation (charge) descriptors</rdfs:label>
        <skos:definition xml:lang="en">The Moreau-Broto autocorrelation descriptors using partial charges.</skos:definition>
        <skos:prefLabel xml:lang="en">MoreauMinusBrotoAutocorrelation(charge)Descriptors</skos:prefLabel>
    </owl:Class>
    


