        <skos:prefLabel xml:lang="en">MolecularFormulaCalculatedByACDLabsPhysChemSoftwareLibraryVersion12.01</skos:prefLabel>
    </owl:Class>
    


    <!-- http://semanticscience.org/resource/CHEMINF_000496 -->


