    sh:node ssbd:ProvActivityShape ;
    sh:property [ sh:or ( [ sh:class ssbd:SsbdDimension ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:assesses ] ;
    sh:targetClass ssbd:Assessment .

