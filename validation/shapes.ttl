@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ssbd: <https://w3id.org/ssbd/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ssbd:AdvancedMaterialShape a sh:NodeShape ;
    sh:targetClass ssbd:AdvancedMaterial .

ssbd:AttributionShape a sh:NodeShape ;
    sh:node ssbd:AgentShape ;
    sh:targetClass prov:Attribution .

ssbd:BooleanDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:BooleanData .

ssbd:ByteDataShape a sh:NodeShape ;
    sh:node ssbd:ShortDataShape ;
    sh:targetClass ssbd:ByteData .

ssbd:ComputationShape a sh:NodeShape ;
    sh:node ssbd:ProcessShape ;
    sh:property [ sh:class ssbd:Software ;
            sh:path ssbd:hasSoftware ] ;
    sh:targetClass ssbd:Computation .

ssbd:ComputationalToolShape a sh:NodeShape ;
    sh:node ssbd:SoftwareShape ;
    sh:targetClass ssbd:ComputationalTool .

ssbd:ConceptShape a sh:NodeShape ;
    sh:targetClass skos:Concept .

ssbd:DataServiceShape a sh:NodeShape ;
    sh:node ssbd:ResourceShape ;
    sh:property [ sh:class <https://w3id.org/emmo/domain/oteio#Parser> ;
            sh:path <https://w3id.org/emmo/domain/oteio#parser> ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:endpointURL ],
        [ sh:class dcat:Dataset ;
            sh:path dcat:servesDataset ],
        [ sh:class rdfs:Resource ;
            sh:path dcat:endpointDescription ] ;
    sh:targetClass dcat:DataService .

ssbd:DatasetSeriesShape a sh:NodeShape ;
    sh:node ssbd:DatasetShape ;
    sh:targetClass dcat:DatasetSeries .

ssbd:DateDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:DateData .

ssbd:DateTimeDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:DateTimeData .

ssbd:DatumShape a sh:NodeShape ;
    sh:node ssbd:DataShape ;
    sh:targetClass ssbd:Datum .

ssbd:DescriptionShape a sh:NodeShape ;
    sh:node ssbd:SignShape ;
    sh:property [ sh:class prov:Entity ;
            sh:path ssbd:isDescriptionOf ] ;
    sh:targetClass ssbd:Description .

ssbd:DistributionShape a sh:NodeShape ;
    sh:node ssbd:ResourceShape ;
    sh:property [ sh:class dcterms:MediaType ;
            sh:path dcat:packageFormat ],
        [ sh:class skos:Concept ;
            sh:path <http://data.europa.eu/r5r/status> ],
        [ sh:datatype xsd:datetime ;
            sh:path <http://data.europa.eu/r5r/availability> ],
        [ sh:class dcat:DataService ;
            sh:path dcat:accessService ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:path dcat:byteSize ],
        [ sh:class rdfs:Resource ;
            sh:path dcat:accessURL ],
        [ sh:class <https://w3id.org/emmo/domain/oteio#Generator> ;
            sh:path <https://w3id.org/emmo/domain/oteio#generator> ],
        [ sh:class dcterms:MediaType ;
            sh:path dcat:compressFormat ],
        [ sh:class <http://spdx.org/rdf/terms#Checksum> ;
            sh:path <http://spdx.org/rdf/terms#checksum> ],
        [ sh:class dcterms:MediaTypeOrExtent ;
            sh:path dcterms:format ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:downloadURL ],
        [ sh:class dcterms:MediaType ;
            sh:path dcat:mediaType ] ;
    sh:targetClass dcat:Distribution .

ssbd:DoubleDataShape a sh:NodeShape ;
    sh:node ssbd:NumericalDataShape ;
    sh:targetClass ssbd:DoubleData .

ssbd:FloatDataShape a sh:NodeShape ;
    sh:node ssbd:NumericalDataShape ;
    sh:targetClass ssbd:FloatData .

ssbd:IndicatorShape a sh:NodeShape ;
    sh:node ssbd:PropertyShape ;
    sh:targetClass ssbd:Indicator .

ssbd:InformationShape a sh:NodeShape ;
    sh:node ssbd:DataShape,
        ssbd:SignShape ;
    sh:targetClass ssbd:Information .

ssbd:InterpreterShape a sh:NodeShape ;
    sh:node ssbd:AgentShape ;
    sh:targetClass ssbd:Interpreter .

ssbd:LicenseDocumentShape a sh:NodeShape ;
    sh:node ssbd:RightsStatementShape ;
    sh:targetClass dcterms:LicenseDocument .

ssbd:LocationShape a sh:NodeShape ;
    sh:property [ sh:class <http://www.w3.org/ns/locn#Geometry> ;
            sh:path <http://www.w3.org/ns/locn#geometry> ],
        [ sh:path dcat:centroid ],
        [ sh:path dcat:bbox ] ;
    sh:targetClass dcterms:Location .

ssbd:MaterialProcessShape a sh:NodeShape ;
    sh:node ssbd:ProcessShape ;
    sh:targetClass ssbd:MaterialProcess .

ssbd:MatterShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:Matter .

ssbd:MeasurementShape a sh:NodeShape ;
    sh:node ssbd:ProcessShape ;
    sh:targetClass ssbd:Measurement .

ssbd:MediaTypeShape a sh:NodeShape ;
    sh:targetClass dcterms:MediaType .

ssbd:ModelShape a sh:NodeShape ;
    sh:node ssbd:SignShape ;
    sh:targetClass ssbd:Model .

ssbd:ParticipantShape a sh:NodeShape ;
    sh:node ssbd:AgentShape,
        ssbd:ObjectShape ;
    sh:targetClass ssbd:Participant .

ssbd:RelationshipShape a sh:NodeShape ;
    sh:property [ sh:class rdfs:Resource ;
            sh:path dcterms:relation ],
        [ sh:class dcat:Role ;
            sh:path dcat:hasRole ] ;
    sh:targetClass dcat:Relationship .

ssbd:ReliabilityDocumentShape a sh:NodeShape ;
    sh:node ssbd:DocumentShape ;
    sh:targetClass ssbd:ReliabilityDocument .

ssbd:SsbdDimensionShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:SsbdDimension .

ssbd:StandardShape a sh:NodeShape ;
    sh:targetClass dcterms:Standard .

ssbd:TierLevelShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:TierLevel .

ssbd:TimeDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:TimeData .

ssbd:ToxicityShape a sh:NodeShape ;
    sh:node ssbd:SignShape ;
    sh:targetClass ssbd:Toxicity .

ssbd:ActivityShape a sh:NodeShape ;
    sh:property [ sh:class prov:Activity ;
            sh:path ssbd:wasInformedBy ],
        [ sh:class prov:Entity ;
            sh:path ssbd:hasInput ],
        [ sh:class prov:Agent ;
            sh:path prov:wasAssociatedWith ],
        [ sh:class prov:Entity ;
            sh:path ssbd:hasOutput ],
        [ sh:class prov:Agent ;
            sh:path ssbd:wasAssociatedWith ],
        [ sh:class prov:Activity ;
            sh:path prov:wasInformedBy ],
        [ sh:class prov:Entity ;
            sh:path ssbd:used ],
        [ sh:class prov:Entity ;
            sh:path prov:used ] ;
    sh:targetClass prov:Activity .

ssbd:IntDataShape a sh:NodeShape ;
    sh:node ssbd:LongDataShape ;
    sh:targetClass ssbd:IntData .

ssbd:IntegerDataShape a sh:NodeShape ;
    sh:node ssbd:NumericalDataShape ;
    sh:targetClass ssbd:IntegerData .

ssbd:LongDataShape a sh:NodeShape ;
    sh:node ssbd:IntegerDataShape ;
    sh:targetClass ssbd:LongData .

ssbd:ObjectShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:Object .

ssbd:PropertyShape a sh:NodeShape ;
    sh:node ssbd:SignShape ;
    sh:property [ sh:path ssbd:hasUnit ],
        [ sh:class prov:Entity ;
            sh:path ssbd:isPropertyOf ] ;
    sh:targetClass ssbd:Property .

ssbd:RightsStatementShape a sh:NodeShape ;
    sh:node ssbd:DocumentShape ;
    sh:targetClass dcterms:RightsStatement .

ssbd:ShortDataShape a sh:NodeShape ;
    sh:node ssbd:IntDataShape ;
    sh:targetClass ssbd:ShortData .

ssbd:SoftwareShape a sh:NodeShape ;
    sh:node ssbd:DataShape ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:path ssbd:hasGUI ],
        [ sh:datatype xsd:boolean ;
            sh:path ssbd:hasAPI ],
        [ sh:class ssbd:Model ;
            sh:path ssbd:implementsModel ],
        [ sh:class ssbd:Software ;
            sh:path ssbd:priorRelease ] ;
    sh:targetClass ssbd:Software .

ssbd:DatasetShape a sh:NodeShape ;
    sh:node ssbd:DataShape,
        ssbd:DatasetShape,
        ssbd:ResourceShape ;
    sh:property [ sh:class ssbd:Datum ;
            sh:path ssbd:hasPart ],
        [ sh:class dcat:Dataset ;
            sh:path dcterms:source ],
        [ sh:class <https://w3id.org/emmo/domain/oteio#Datamodel> ;
            sh:path <https://w3id.org/emmo/domain/oteio#hasDatamodel> ],
        [ sh:class dcterms:PeriodOfTime ;
            sh:path dcterms:temporal ],
        [ sh:path <https://w3id.org/emmo/domain/oteio#mappingFormat> ],
        [ sh:class <http://www.w3.org/ns/adms#Identifier> ;
            sh:path <http://www.w3.org/ns/adms#identifier> ],
        [ sh:class dcat:Distribution ;
            sh:path dcat:distribution ],
        [ sh:class dcat:DatasetSeries ;
            sh:path dcat:inSeries ],
        [ sh:class dcat:Distribution ;
            sh:path <http://www.w3.org/ns/adms#sample> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <https://w3id.org/emmo/domain/oteio#hasDatamodelStorage> ],
        [ sh:class prov:Activity ;
            sh:path prov:wasGeneratedBy ],
        [ sh:class ssbd:Datum ;
            sh:path ssbd:hasDatum ],
        [ sh:datatype xsd:duration ;
            sh:path dcat:temporalResolution ],
        [ sh:class dcat:Resource ;
            sh:path prov:wasDerivedFrom ],
        [ sh:class dcterms:Frequency ;
            sh:path dcterms:accrualPeriodicity ],
        [ sh:datatype xsd:anyURI ;
            sh:path <https://w3id.org/emmo/domain/oteio#mappingURL> ],
        [ sh:class dcterms:Location ;
            sh:path dcterms:spatial ],
        [ sh:class rdf:JSON ;
            sh:path <https://w3id.org/emmo/domain/oteio#mapping> ],
        [ sh:datatype xsd:decimal ;
            sh:path dcat:spatialResolutionInMeters ] ;
    sh:targetClass dcat:Dataset,
        ssbd:Dataset .

ssbd:DocumentShape a sh:NodeShape ;
    sh:node ssbd:DataShape ;
    sh:targetClass foaf:Document .

ssbd:NumericalDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:NumericalData .

ssbd:ProcessShape a sh:NodeShape ;
    sh:node ssbd:ActivityShape ;
    sh:targetClass ssbd:Process .

ssbd:ResourceShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:property [ sh:class <http://www.w3.org/2006/vcard/ns#Kind> ;
            sh:path dcat:contactPoint ],
        [ sh:path dcterms:bibliographicCitation ],
        [ sh:class <http://data.europa.eu/eli/ontology#LegalResource> ;
            sh:path <http://data.europa.eu/r5r/applicableLegislation> ],
        [ sh:class foaf:Document ;
            sh:path ssbd:documentation ],
        [ sh:class <https://w3id.org/emmo/application/datadoc#ConformanceLevel> ;
            sh:path <https://w3id.org/emmo/application/datadoc#conformance> ],
        [ sh:class dcterms:RightsStatement ;
            sh:path dcterms:accessRights ],
        [ sh:class rdfs:Resource ;
            sh:path dcterms:isReferencedBy ],
        [ sh:class foaf:Document ;
            sh:path dcat:landingPage ],
        [ sh:class skos:Concept ;
            sh:path dcat:theme ],
        [ sh:datatype rdf:langString ;
            sh:path dcterms:abstract ],
        [ sh:class foaf:Agent ;
            sh:path <https://w3id.org/emmo/application/datadoc#curator> ],
        [ sh:datatype rdf:langString ;
            sh:path dcat:keyword ],
        [ sh:class foaf:Document ;
            sh:path foaf:page ],
        [ sh:datatype xsd:datetime ;
            sh:path dcterms:modified ],
        [ sh:class prov:Attribution ;
            sh:path prov:qualifiedAttribution ],
        [ sh:class rdf:JSON ;
            sh:path <https://w3id.org/emmo/domain/oteio#statement> ],
        [ sh:class foaf:Agent ;
            sh:path dcterms:publisher ],
        [ sh:datatype xsd:string ;
            sh:path dcterms:language ],
        [ sh:class dcat:Relationship ;
            sh:path dcat:qualifiedRelation ],
        [ sh:class rdfs:Resource ;
            sh:path dcat:hasVersion ],
        [ sh:class dcterms:LicenseDocument ;
            sh:path dcterms:license ],
        [ sh:class dcterms:Standard ;
            sh:path dcterms:conformsTo ],
        [ sh:datatype xsd:datetime ;
            sh:path <https://w3id.org/emmo/application/datadoc#curationDate> ],
        [ sh:datatype rdf:langString ;
            sh:path dcterms:title ],
        [ sh:class foaf:Agent ;
            sh:path dcterms:creator ],
        [ sh:path dcat:version ],
        [ sh:datatype rdf:langString ;
            sh:path skos:definition ],
        [ sh:datatype xsd:dateTime ;
            sh:path dcterms:issued ],
        [ sh:class foaf:Agent ;
            sh:path dcterms:contributor ],
        [ sh:datatype xsd:string ;
            sh:path <https://w3id.org/emmo/application/datadoc#unitSymbol> ] ;
    sh:targetClass dcat:Resource .

ssbd:AgentShape a sh:NodeShape ;
    sh:node ssbd:AgentShape ;
    sh:property [ sh:path dcterms:identifier ],
        [ sh:class prov:Entity ;
            sh:path ssbd:attributed ],
        [ sh:datatype xsd:string ;
            sh:path foaf:name ] ;
    sh:targetClass prov:Agent,
        foaf:Agent .

ssbd:SignShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:property [ sh:class prov:Entity ;
            sh:path ssbd:standsFor ],
        [ sh:class ssbd:Interpreter ;
            sh:path ssbd:isInterpretedBy ] ;
    sh:targetClass ssbd:Sign .

ssbd:SymbolicDataShape a sh:NodeShape ;
    sh:node ssbd:DataShape ;
    sh:targetClass ssbd:SymbolicData .

ssbd:DataShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:Data .

ssbd:EntityShape a sh:NodeShape ;
    sh:property [ sh:class prov:Activity ;
            sh:path ssbd:wasGeneratedBy ],
        [ sh:class ssbd:Description ;
            sh:path ssbd:hasDescription ],
        [ sh:class prov:Entity ;
            sh:path ssbd:wasDerivedBy ],
        [ sh:class ssbd:TierLevel ;
            sh:path ssbd:tierLevel ],
        [ sh:class prov:Agent ;
            sh:path ssbd:wasAttributedTo ],
        [ sh:class prov:Activity ;
            sh:path ssbd:participatesTo ],
        [ sh:class ssbd:Sign ;
            sh:path ssbd:isRepresentedBy ],
        [ sh:class ssbd:Property ;
            sh:path ssbd:hasProperty ],
        [ sh:class ssbd:Matter ;
            sh:path ssbd:chemicalClass ],
        [ sh:class prov:Agent ;
            sh:path prov:wasAttributedTo ] ;
    sh:targetClass prov:Entity .
