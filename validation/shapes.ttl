ssbd:SsbdNanoObjectShape a sh:NodeShape ;
    sh:targetClass ssbd:NanoObject .

ssbd:SsbdNumericalDataShape a sh:NodeShape ;
    sh:node ssbd:SsbdSymbolicDataShape ;
