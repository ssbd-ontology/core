ssbd:NanoTubeShape a sh:NodeShape ;
    sh:node ssbd:NanoFiberShape ;
    sh:targetClass ssbd:NanoTube .

ssbd:NaturalLanguageClassificationShape a sh:NodeShape ;
    sh:node ssbd:NaturalLanguageUnderstandingShape ;
    sh:targetClass ssbd:NaturalLanguageClassification .

ssbd:ObjectDetectionShape a sh:NodeShape ;
    sh:node ssbd:ComputerVisionShape ;
    sh:targetClass ssbd:ObjectDetection .

ssbd:OpticalMaterialShape a sh:NodeShape ;
    sh:targetClass ssbd:OpticalMaterial .

ssbd:ParticipantShape a sh:NodeShape ;
    sh:node ssbd:AgentShape,
        ssbd:ObjectShape ;
    sh:targetClass ssbd:Participant .

ssbd:PlanningModelShape a sh:NodeShape ;
    sh:node ssbd:CognitionAndLearningModelShape ;
    sh:targetClass ssbd:PlanningModel .

ssbd:PoissonsRatioAssessmentShape a sh:NodeShape ;
    sh:node ssbd:MechanicalPropertiesAssessmentShape ;
