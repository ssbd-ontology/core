@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ssbd: <https://w3id.org/ssbd/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ssbd:AbductiveReasoningModelShape a sh:NodeShape ;
    sh:node ssbd:CognitionAndLearningModelShape ;
    sh:targetClass ssbd:AbductiveReasoningModel .

ssbd:AdaboostShape a sh:NodeShape ;
    sh:node ssbd:ClassificationShape ;
    sh:targetClass ssbd:Adaboost .

ssbd:AdvancedMaterialShape a sh:NodeShape ;
    sh:targetClass ssbd:AdvancedMaterial .

ssbd:AnalogicalReasoningModelShape a sh:NodeShape ;
    sh:node ssbd:CognitionAndLearningModelShape ;
    sh:targetClass ssbd:AnalogicalReasoningModel .

ssbd:AttributionShape a sh:NodeShape ;
    sh:node ssbd:AgentShape ;
    sh:targetClass prov:Attribution .

ssbd:AutoencoderShape a sh:NodeShape ;
    sh:node ssbd:ArtificialNeuralNetworkShape,
        ssbd:DimensionalityReductionShape ;
    sh:targetClass ssbd:Autoencoder .

ssbd:BaggingShape a sh:NodeShape ;
    sh:node ssbd:PredictionLearningModelShape ;
    sh:targetClass ssbd:Bagging .

ssbd:BehaviorModelShape a sh:NodeShape ;
    sh:targetClass ssbd:BehaviorModel .

ssbd:BiocompatibleMaterialShape a sh:NodeShape ;
    sh:targetClass ssbd:BiocompatibleMaterial .

ssbd:BooleanDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:BooleanData .

ssbd:BoostingShape a sh:NodeShape ;
    sh:node ssbd:PredictionLearningModelShape ;
    sh:targetClass ssbd:Boosting .

ssbd:BulkModulusAssessmentShape a sh:NodeShape ;
    sh:node ssbd:MechanicalPropertiesAssessmentShape ;
    sh:targetClass ssbd:BulkModulusAssessment .

ssbd:ByteDataShape a sh:NodeShape ;
    sh:node ssbd:ShortDataShape ;
    sh:targetClass ssbd:ByteData .

ssbd:ClusteringShape a sh:NodeShape ;
    sh:node ssbd:UnsupervicedLearningModelShape ;
    sh:targetClass ssbd:Clustering .

ssbd:CollaborativeFilteringShape a sh:NodeShape ;
    sh:node ssbd:RecommenderSystemShape ;
    sh:targetClass ssbd:CollaborativeFiltering .

ssbd:ComputationShape a sh:NodeShape ;
    sh:node ssbd:ProcessShape ;
    sh:property [ sh:or ( [ sh:class ssbd:Software ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasSoftware ] ;
    sh:targetClass ssbd:Computation .

ssbd:ComputationalToolShape a sh:NodeShape ;
    sh:node ssbd:SoftwareShape ;
    sh:targetClass ssbd:ComputationalTool .

ssbd:ConceptShape a sh:NodeShape ;
    sh:targetClass skos:Concept .

ssbd:ContentExtractionShape a sh:NodeShape ;
    sh:node ssbd:NaturalLanguageUnderstandingShape ;
    sh:targetClass ssbd:ContentExtraction .

ssbd:ConvolutionNeuralNetworkShape a sh:NodeShape ;
    sh:node ssbd:DeepLearningModelShape ;
    sh:targetClass ssbd:ConvolutionNeuralNetwork .

ssbd:DataServiceShape a sh:NodeShape ;
    sh:node ssbd:ResourceShape ;
    sh:property [ sh:or ( [ sh:class dcat:Dataset ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:servesDataset ],
        [ sh:or ( [ sh:class <https://w3id.org/emmo/domain/oteio#Parser> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#parser> ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:endpointURL ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:endpointDescription ] ;
    sh:targetClass dcat:DataService .

ssbd:DatasetSeriesShape a sh:NodeShape ;
    sh:node ssbd:DatasetShape ;
    sh:targetClass dcat:DatasetSeries .

ssbd:DateDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:DateData .

ssbd:DateTimeDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:DateTimeData .

ssbd:DatumShape a sh:NodeShape ;
    sh:node ssbd:DataShape ;
    sh:targetClass ssbd:Datum .

ssbd:DecisionTreeShape a sh:NodeShape ;
    sh:node ssbd:ClassificationShape ;
    sh:targetClass ssbd:DecisionTree .

ssbd:DeepFeedForwardNetworkShape a sh:NodeShape ;
    sh:node ssbd:DeepLearningModelShape ;
    sh:targetClass ssbd:DeepFeedForwardNetwork .

ssbd:DensityAssessmentShape a sh:NodeShape ;
    sh:node ssbd:PhysicalPropertiesAssessmentShape ;
    sh:targetClass ssbd:DensityAssessment .

ssbd:DescriptionShape a sh:NodeShape ;
    sh:node ssbd:SignShape ;
    sh:property [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:isDescriptionOf ] ;
    sh:targetClass ssbd:Description .

ssbd:DistributionShape a sh:NodeShape ;
    sh:node ssbd:ResourceShape ;
    sh:property [ sh:or ( [ sh:class <https://w3id.org/emmo/domain/oteio#Generator> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#generator> ],
        [ sh:or ( [ sh:class dcterms:MediaTypeOrExtent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:format ],
        [ sh:datatype xsd:dateTime ;
            sh:path <http://data.europa.eu/r5r/availability> ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:accessURL ],
        [ sh:or ( [ sh:class dcat:DataService ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:accessService ],
        [ sh:or ( [ sh:class dcterms:MediaType ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:compressFormat ],
        [ sh:or ( [ sh:class skos:Concept ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://data.europa.eu/r5r/status> ],
        [ sh:or ( [ sh:class dcterms:MediaType ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:mediaType ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:path dcat:byteSize ],
        [ sh:or ( [ sh:class <http://spdx.org/rdf/terms#Checksum> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://spdx.org/rdf/terms#checksum> ],
        [ sh:or ( [ sh:class dcterms:MediaType ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:packageFormat ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:downloadURL ] ;
    sh:targetClass dcat:Distribution .

ssbd:DomainOfApplicabilityStatusShape a sh:NodeShape ;
    sh:node ssbd:PropertyShape ;
    sh:targetClass ssbd:DomainOfApplicabilityStatus .

ssbd:DoubleDataShape a sh:NodeShape ;
    sh:node ssbd:NumericalDataShape ;
    sh:targetClass ssbd:DoubleData .

ssbd:DynamicProgrammingShape a sh:NodeShape ;
    sh:node ssbd:ReinforcedLearningModelShape ;
    sh:targetClass ssbd:DynamicProgramming .

ssbd:EconomicDimensionShape a sh:NodeShape ;
