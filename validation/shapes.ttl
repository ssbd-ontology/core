ssbd:ImageSegmentationShape a sh:NodeShape ;
    sh:node ssbd:ComputerVisionShape ;
    sh:targetClass ssbd:ImageSegmentation .

ssbd:InformationShape a sh:NodeShape ;
    sh:node ssbd:DataShape,
        ssbd:SignShape ;
    sh:targetClass ssbd:Information .

ssbd:InterpreterShape a sh:NodeShape ;
    sh:node ssbd:AgentShape ;
    sh:targetClass ssbd:Interpreter .

ssbd:LargeLanguageModelShape a sh:NodeShape ;
    sh:node ssbd:ModernGenerativeAIModelShape,
        ssbd:TextGenerationShape ;
    sh:targetClass ssbd:LargeLanguageModel .

ssbd:LicenseDocumentShape a sh:NodeShape ;
    sh:node ssbd:RightsStatementShape ;
    sh:targetClass dcterms:LicenseDocument .

ssbd:LinearDiscriminantAnalysisShape a sh:NodeShape ;
    sh:node ssbd:DimensionalityReductionShape ;
    sh:targetClass ssbd:LinearDiscriminantAnalysis .

ssbd:LocationShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class <http://www.w3.org/ns/locn#Geometry> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://www.w3.org/ns/locn#geometry> ],
        [ sh:path dcat:centroid ],
        [ sh:path dcat:bbox ] ;
    sh:targetClass dcterms:Location .

ssbd:LogicShape a sh:NodeShape ;
    sh:node ssbd:CognitionAndLearningModelShape ;
    sh:targetClass ssbd:Logic .

ssbd:LogisticRegressionModelShape a sh:NodeShape ;
