@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ssbd: <https://w3id.org/ssbd/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ssbd:DcatDataServiceShape a sh:NodeShape ;
    sh:node ssbd:DcatResourceShape ;
    sh:property [ sh:or ( [ sh:class <https://w3id.org/emmo/domain/oteio#Parser> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#parser> ],
        [ sh:or ( [ sh:class dcat:Dataset ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:servesDataset ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:endpointURL ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:endpointDescription ] ;
    sh:targetClass dcat:DataService .

ssbd:DcatDatasetSeriesShape a sh:NodeShape ;
    sh:node ssbd:DcatDatasetShape ;
    sh:targetClass dcat:DatasetSeries .

ssbd:DcatDistributionShape a sh:NodeShape ;
    sh:node ssbd:DcatResourceShape ;
    sh:property [ sh:or ( [ sh:class dcterms:MediaTypeOrExtent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:format ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:accessURL ],
        [ sh:or ( [ sh:class <http://spdx.org/rdf/terms#Checksum> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://spdx.org/rdf/terms#checksum> ],
        [ sh:or ( [ sh:class dcterms:MediaType ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:packageFormat ],
        [ sh:or ( [ sh:class dcterms:MediaType ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:compressFormat ],
        [ sh:datatype xsd:dateTime ;
            sh:path <http://data.europa.eu/r5r/availability> ],
        [ sh:datatype xsd:anyURI ;
            sh:path dcat:downloadURL ],
        [ sh:datatype xsd:nonNegativeInteger ;
            sh:path dcat:byteSize ],
        [ sh:or ( [ sh:class <https://w3id.org/emmo/domain/oteio#Generator> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#generator> ],
        [ sh:or ( [ sh:class dcterms:MediaType ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:mediaType ],
        [ sh:or ( [ sh:class skos:Concept ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://data.europa.eu/r5r/status> ],
        [ sh:or ( [ sh:class dcat:DataService ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:accessService ] ;
    sh:targetClass dcat:Distribution .

ssbd:DcatRelationshipShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class dcat:Role ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:hasRole ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:relation ] ;
    sh:targetClass dcat:Relationship .

ssbd:DctermsLicenseDocumentShape a sh:NodeShape ;
    sh:node ssbd:DctermsRightsStatementShape ;
    sh:targetClass dcterms:LicenseDocument .

ssbd:DctermsLocationShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class <http://www.w3.org/ns/locn#Geometry> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://www.w3.org/ns/locn#geometry> ],
        [ sh:path dcat:bbox ],
        [ sh:path dcat:centroid ] ;
    sh:targetClass dcterms:Location .

ssbd:DctermsMediaTypeShape a sh:NodeShape ;
    sh:targetClass dcterms:MediaType .

ssbd:DctermsStandardShape a sh:NodeShape ;
    sh:targetClass dcterms:Standard .

ssbd:ProvAttributionShape a sh:NodeShape ;
