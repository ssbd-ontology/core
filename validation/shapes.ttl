        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasAttributedTo ],
        [ sh:or ( [ sh:class ssbd:Matter ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:chemicalClass ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasDerivedBy ],
        [ sh:or ( [ sh:class ssbd:Sign ] [ sh:nodeKind sh:IRI ] ) ;
