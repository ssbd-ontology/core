ssbd:DcatDatasetShape a sh:NodeShape ;
    sh:node ssbd:DcatResourceShape,
        ssbd:SsbdDataShape ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:path dcat:spatialResolutionInMeters ],
        [ sh:datatype xsd:duration ;
            sh:path dcat:temporalResolution ],
        [ sh:or ( [ sh:class dcterms:PeriodOfTime ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:temporal ],
        [ sh:datatype xsd:anyURI ;
            sh:path <https://w3id.org/emmo/domain/oteio#mappingURL> ],
        [ sh:or ( [ sh:class rdf:JSON ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#mapping> ],
        [ sh:datatype xsd:anyURI ;
            sh:path <https://w3id.org/emmo/domain/oteio#hasDatamodelStorage> ],
        [ sh:or ( [ sh:class dcterms:Location ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:spatial ],
        [ sh:or ( [ sh:class dcat:DatasetSeries ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:inSeries ],
        [ sh:path <https://w3id.org/emmo/domain/oteio#mappingFormat> ],
        [ sh:or ( [ sh:class dcat:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasDerivedFrom ],
        [ sh:or ( [ sh:class dcat:Distribution ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://www.w3.org/ns/adms#sample> ],
        [ sh:or ( [ sh:class dcat:Dataset ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:source ],
        [ sh:or ( [ sh:class dcterms:Frequency ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:accrualPeriodicity ],
        [ sh:or ( [ sh:class <https://w3id.org/emmo/domain/oteio#Datamodel> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#hasDatamodel> ],
        [ sh:or ( [ sh:class <http://www.w3.org/ns/adms#Identifier> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://www.w3.org/ns/adms#identifier> ],
        [ sh:or ( [ sh:class dcat:Distribution ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:distribution ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasGeneratedBy ] ;
    sh:targetClass dcat:Dataset .

ssbd:FoafDocumentShape a sh:NodeShape ;
    sh:node ssbd:SsbdDataShape ;
    sh:targetClass foaf:Document .

ssbd:ProvActivityShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasAssociatedWith ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasOutput ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasInformedBy ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasInput ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasAssociatedWith ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasInformedBy ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:used ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:used ] ;
    sh:targetClass prov:Activity .

ssbd:SsbdArtificialNeuralNetworkShape a sh:NodeShape ;
    sh:targetClass ssbd:ArtificialNeuralNetwork .

ssbd:SsbdNanoFiberShape a sh:NodeShape ;
    sh:node ssbd:SsbdNanoObjectShape ;
    sh:targetClass ssbd:NanoFiber .

ssbd:SsbdPropertyShape a sh:NodeShape ;
    sh:node ssbd:SsbdSignShape ;
    sh:property [ sh:path ssbd:hasMeasurementUnit ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:isPropertyOf ] ;
    sh:targetClass ssbd:Property .

ssbd:SsbdRegressionModelShape a sh:NodeShape ;
    sh:node ssbd:SsbdSupervisedLearningModelShape ;
    sh:targetClass ssbd:RegressionModel .

ssbd:DcatResourceShape a sh:NodeShape ;
    sh:node ssbd:ProvEntityShape ;
    sh:property [ sh:or ( [ sh:class <http://www.w3.org/2006/vcard/ns#Kind> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:contactPoint ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:publisher ],
        [ sh:datatype xsd:dateTime ;
            sh:path dcterms:issued ],
        [ sh:datatype xsd:string ;
            sh:path <https://w3id.org/emmo/application/datadoc#unitSymbol> ],
        [ sh:or ( [ sh:class dcterms:RightsStatement ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:accessRights ],
        [ sh:path dcterms:bibliographicCitation ],
        [ sh:or ( [ sh:class <https://w3id.org/emmo/application/datadoc#ConformanceLevel> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/application/datadoc#conformance> ],
        [ sh:datatype xsd:string ;
            sh:path dcterms:language ],
        [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path foaf:page ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:hasVersion ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:creator ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/application/datadoc#curator> ],
        [ sh:or ( [ sh:class prov:Attribution ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:qualifiedAttribution ],
        [ sh:or ( [ sh:class <http://data.europa.eu/eli/ontology#LegalResource> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://data.europa.eu/r5r/applicableLegislation> ],
        [ sh:or ( [ sh:class dcterms:LicenseDocument ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:license ],
        [ sh:datatype xsd:dateTime ;
            sh:path dcterms:modified ],
        [ sh:path dcat:version ],
        [ sh:or ( [ sh:class rdf:JSON ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#statement> ],
        [ sh:datatype xsd:dateTime ;
            sh:path <https://w3id.org/emmo/application/datadoc#curationDate> ],
        [ sh:or ( [ sh:class dcat:Relationship ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:qualifiedRelation ],
        [ sh:datatype rdf:langString ;
            sh:path dcterms:abstract ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:contributor ],
        [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:landingPage ],
        [ sh:datatype rdf:langString ;
            sh:path skos:definition ],
        [ sh:or ( [ sh:class dcterms:Standard ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:conformsTo ],
        [ sh:or ( [ sh:class skos:Concept ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:theme ],
        [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:documentation ],
        [ sh:datatype rdf:langString ;
            sh:path dcterms:title ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:isReferencedBy ] ;
    sh:targetClass dcat:Resource .

ssbd:ProvAgentShape a sh:NodeShape ;
    sh:node ssbd:FoafAgentShape ;
    sh:property [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:attributed ] ;
    sh:targetClass prov:Agent .

ssbd:SsbdFunctionalityAssessmentShape a sh:NodeShape ;
