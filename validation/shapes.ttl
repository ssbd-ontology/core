ssbd:ProbabilityModelShape a sh:NodeShape ;
    sh:node ssbd:CognitionAndLearningModelShape ;
    sh:targetClass ssbd:ProbabilityModel .

ssbd:ProfilerShape a sh:NodeShape ;
    sh:node ssbd:SoftwareShape ;
    sh:targetClass ssbd:Profiler .

ssbd:ProteinShape a sh:NodeShape ;
    sh:targetClass ssbd:Protein .

ssbd:QSARModelShape a sh:NodeShape ;
    sh:targetClass ssbd:QSARModel .

ssbd:QSARSoftwareShape a sh:NodeShape ;
    sh:node ssbd:SoftwareShape ;
    sh:property [ sh:or ( [ sh:class ssbd:QSARModel ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:implementsModel ] ;
    sh:targetClass ssbd:QSARSoftware .

ssbd:QuestionAnsweringShape a sh:NodeShape ;
    sh:node ssbd:NaturalLanguageUnderstandingShape ;
    sh:targetClass ssbd:QuestionAnswering .

ssbd:RandomForestShape a sh:NodeShape ;
    sh:node ssbd:PredictionLearningModelShape ;
    sh:targetClass ssbd:RandomForest .

ssbd:RecurrentNeuralNetworkShape a sh:NodeShape ;
    sh:node ssbd:DeepLearningModelShape ;
    sh:targetClass ssbd:RecurrentNeuralNetwork .

ssbd:RelationshipShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:relation ],
        [ sh:or ( [ sh:class dcat:Role ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:hasRole ] ;
    sh:targetClass dcat:Relationship .

ssbd:ReliabilityDocumentShape a sh:NodeShape ;
    sh:node ssbd:DocumentShape ;
    sh:targetClass ssbd:ReliabilityDocument .

ssbd:SafetyDimensionShape a sh:NodeShape ;
    sh:node ssbd:SsbdDimensionShape ;
    sh:targetClass ssbd:SafetyDimension .

ssbd:SelfTrainingModelShape a sh:NodeShape ;
    sh:node ssbd:SemiSupervicedLearningModelShape ;
    sh:targetClass ssbd:SelfTrainingModel .

ssbd:SiameseNeuralNetworkShape a sh:NodeShape ;
    sh:node ssbd:DeepLearningModelShape ;
    sh:targetClass ssbd:SiameseNeuralNetwork .

ssbd:SocialDimensionShape a sh:NodeShape ;
    sh:node ssbd:SsbdDimensionShape ;
    sh:targetClass ssbd:SocialDimension .

ssbd:StandardShape a sh:NodeShape ;
    sh:targetClass dcterms:Standard .

ssbd:StepwiseRegressionModelShape a sh:NodeShape ;
    sh:node ssbd:RegressionModelShape ;
    sh:targetClass ssbd:StepwiseRegressionModel .

ssbd:StructuralMaterialShape a sh:NodeShape ;
    sh:targetClass ssbd:StructuralMaterial .

ssbd:SupportVectorMachineShape a sh:NodeShape ;
    sh:node ssbd:ClassificationShape ;
    sh:targetClass ssbd:SupportVectorMachine .

ssbd:TDistributedStochasticNeighborEmbeddingShape a sh:NodeShape ;
    sh:node ssbd:DimensionalityReductionShape ;
    sh:targetClass ssbd:TDistributedStochasticNeighborEmbedding .

ssbd:TargetTrackingShape a sh:NodeShape ;
    sh:node ssbd:ComputerVisionShape ;
    sh:targetClass ssbd:TargetTracking .

ssbd:TierLevelShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:TierLevel .

ssbd:TimeDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:TimeData .

ssbd:ToxicityShape a sh:NodeShape ;
    sh:node ssbd:IndicatorShape ;
    sh:targetClass ssbd:Toxicity .

ssbd:XGBoostRegessorShape a sh:NodeShape ;
    sh:node ssbd:PredictionLearningModelShape ;
    sh:targetClass ssbd:XGBoostRegessor .

ssbd:YoungsModulusAssessmentShape a sh:NodeShape ;
    sh:node ssbd:MechanicalPropertiesAssessmentShape ;
    sh:targetClass ssbd:YoungsModulusAssessment .

ssbd:AssessmentShape a sh:NodeShape ;
    sh:node ssbd:ActivityShape ;
    sh:property [ sh:or ( [ sh:class ssbd:SsbdDimension ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:assesses ] ;
    sh:targetClass ssbd:Assessment .

ssbd:EnsembleLearningModelShape a sh:NodeShape ;
    sh:targetClass ssbd:EnsembleLearningModel .

ssbd:IndicatorShape a sh:NodeShape ;
    sh:node ssbd:PropertyShape ;
    sh:targetClass ssbd:Indicator .

ssbd:IntDataShape a sh:NodeShape ;
    sh:node ssbd:LongDataShape ;
    sh:targetClass ssbd:IntData .

ssbd:IntegerDataShape a sh:NodeShape ;
    sh:node ssbd:NumericalDataShape ;
    sh:targetClass ssbd:IntegerData .

ssbd:KnowledgeRepresentationShape a sh:NodeShape ;
    sh:node ssbd:CognitionAndLearningModelShape ;
    sh:targetClass ssbd:KnowledgeRepresentation .

ssbd:LongDataShape a sh:NodeShape ;
    sh:node ssbd:IntegerDataShape ;
    sh:targetClass ssbd:LongData .

ssbd:ModernGenerativeAIModelShape a sh:NodeShape ;
    sh:node ssbd:TransformerAIShape ;
    sh:targetClass ssbd:ModernGenerativeAIModel .

ssbd:NanoStructuredMaterialShape a sh:NodeShape ;
    sh:targetClass ssbd:NanoStructuredMaterial .

ssbd:NaturalLanguageGenerationShape a sh:NodeShape ;
    sh:targetClass ssbd:NaturalLanguageGeneration .

ssbd:ObjectShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:Object .

ssbd:PerceptionModelShape a sh:NodeShape ;
    sh:targetClass ssbd:PerceptionModel .

ssbd:PhysicalPropertiesAssessmentShape a sh:NodeShape ;
    sh:node ssbd:FunctionalityAssessmentShape ;
    sh:targetClass ssbd:PhysicalPropertiesAssessment .

ssbd:RecommenderSystemShape a sh:NodeShape ;
    sh:node ssbd:SupervisedLearningModelShape ;
    sh:targetClass ssbd:RecommenderSystem .

ssbd:RightsStatementShape a sh:NodeShape ;
    sh:node ssbd:DocumentShape ;
    sh:targetClass dcterms:RightsStatement .

ssbd:SSbDAssessmentShape a sh:NodeShape ;
    sh:node ssbd:AssessmentShape ;
    sh:targetClass ssbd:SSbDAssessment .

ssbd:ShortDataShape a sh:NodeShape ;
    sh:node ssbd:IntDataShape ;
    sh:targetClass ssbd:ShortData .

ssbd:SpecifiedAssessmentShape a sh:NodeShape ;
    sh:node ssbd:SSbDAssessmentShape ;
    sh:targetClass ssbd:SpecifiedAssessment .

ssbd:TextGenerationShape a sh:NodeShape ;
    sh:node ssbd:NaturalLanguageGenerationShape ;
    sh:targetClass ssbd:TextGeneration .

ssbd:ThermalPropertiesAssessmentShape a sh:NodeShape ;
    sh:node ssbd:FunctionalityAssessmentShape ;
    sh:targetClass ssbd:ThermalPropertiesAssessment .

ssbd:TransformerAIShape a sh:NodeShape ;
    sh:node ssbd:DeepLearningModelShape ;
    sh:targetClass ssbd:TransformerAI .

ssbd:UnsupervicedLearningModelShape a sh:NodeShape ;
    sh:targetClass ssbd:UnsupervicedLearningModel .

ssbd:ActivityShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:used ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:used ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasInformedBy ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasInput ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasAssociatedWith ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasOutput ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasAssociatedWith ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasInformedBy ] ;
    sh:targetClass prov:Activity .

ssbd:ArtificialNeuralNetworkShape a sh:NodeShape ;
    sh:targetClass ssbd:ArtificialNeuralNetwork .

ssbd:DatasetShape a sh:NodeShape ;
    sh:node ssbd:DataShape,
        ssbd:DatasetShape,
        ssbd:ResourceShape ;
    sh:property [ sh:or ( [ sh:class ssbd:Datum ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasPart ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasGeneratedBy ],
        [ sh:or ( [ sh:class dcterms:Frequency ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:accrualPeriodicity ],
        [ sh:datatype xsd:anyURI ;
            sh:path <https://w3id.org/emmo/domain/oteio#hasDatamodelStorage> ],
        [ sh:or ( [ sh:class dcat:Distribution ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:distribution ],
        [ sh:datatype xsd:anyURI ;
            sh:path <https://w3id.org/emmo/domain/oteio#mappingURL> ],
        [ sh:or ( [ sh:class dcat:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasDerivedFrom ],
        [ sh:or ( [ sh:class dcterms:PeriodOfTime ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:temporal ],
        [ sh:path <https://w3id.org/emmo/domain/oteio#mappingFormat> ],
        [ sh:or ( [ sh:class dcat:Distribution ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://www.w3.org/ns/adms#sample> ],
        [ sh:datatype xsd:duration ;
            sh:path dcat:temporalResolution ],
        [ sh:or ( [ sh:class dcterms:Location ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:spatial ],
        [ sh:or ( [ sh:class ssbd:Datum ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasDatum ],
        [ sh:or ( [ sh:class dcat:DatasetSeries ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:inSeries ],
        [ sh:datatype xsd:decimal ;
            sh:path dcat:spatialResolutionInMeters ],
        [ sh:or ( [ sh:class <http://www.w3.org/ns/adms#Identifier> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://www.w3.org/ns/adms#identifier> ],
        [ sh:or ( [ sh:class dcat:Dataset ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:source ],
        [ sh:or ( [ sh:class <https://w3id.org/emmo/domain/oteio#Datamodel> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#hasDatamodel> ],
        [ sh:or ( [ sh:class rdf:JSON ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#mapping> ] ;
    sh:targetClass dcat:Dataset,
        ssbd:Dataset .

ssbd:DocumentShape a sh:NodeShape ;
    sh:node ssbd:DataShape ;
    sh:targetClass foaf:Document .

ssbd:NanoFiberShape a sh:NodeShape ;
    sh:node ssbd:NanoObjectShape ;
    sh:targetClass ssbd:NanoFiber .

ssbd:PropertyShape a sh:NodeShape ;
    sh:node ssbd:SignShape ;
    sh:property [ sh:path ssbd:hasMeasurementUnit ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:isPropertyOf ] ;
    sh:targetClass ssbd:Property .

ssbd:RegressionModelShape a sh:NodeShape ;
    sh:node ssbd:SupervisedLearningModelShape ;
    sh:targetClass ssbd:RegressionModel .

ssbd:FunctionalityAssessmentShape a sh:NodeShape ;
    sh:node ssbd:SpecifiedAssessmentShape ;
    sh:property [ sh:or ( [ sh:class ssbd:FunctionalityDimension ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:assesses ] ;
    sh:targetClass ssbd:FunctionalityAssessment .

ssbd:MechanicalPropertiesAssessmentShape a sh:NodeShape ;
    sh:node ssbd:FunctionalityAssessmentShape ;
    sh:targetClass ssbd:MechanicalPropertiesAssessment .

ssbd:NanoObjectShape a sh:NodeShape ;
    sh:targetClass ssbd:NanoObject .

ssbd:NumericalDataShape a sh:NodeShape ;
    sh:node ssbd:SymbolicDataShape ;
    sh:targetClass ssbd:NumericalData .

ssbd:ProcessShape a sh:NodeShape ;
    sh:node ssbd:ActivityShape ;
    sh:property [ sh:or ( [ sh:class ssbd:Process ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasSubProcess ] ;
    sh:targetClass ssbd:Process .

ssbd:ReinforcedLearningModelShape a sh:NodeShape ;
    sh:targetClass ssbd:ReinforcedLearningModel .

ssbd:ResourceShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:property [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path foaf:page ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:hasVersion ],
        [ sh:datatype rdf:langString ;
            sh:path dcterms:abstract ],
        [ sh:datatype xsd:dateTime ;
            sh:path dcterms:modified ],
        [ sh:or ( [ sh:class prov:Attribution ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:qualifiedAttribution ],
        [ sh:or ( [ sh:class rdf:JSON ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/domain/oteio#statement> ],
        [ sh:datatype xsd:dateTime ;
            sh:path dcterms:issued ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/application/datadoc#curator> ],
        [ sh:or ( [ sh:class dcterms:LicenseDocument ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:license ],
        [ sh:or ( [ sh:class <http://data.europa.eu/eli/ontology#LegalResource> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <http://data.europa.eu/r5r/applicableLegislation> ],
        [ sh:or ( [ sh:class dcterms:RightsStatement ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:accessRights ],
        [ sh:path dcterms:bibliographicCitation ],
        [ sh:or ( [ sh:class dcat:Relationship ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:qualifiedRelation ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:creator ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:contributor ],
        [ sh:datatype xsd:string ;
            sh:path <https://w3id.org/emmo/application/datadoc#unitSymbol> ],
        [ sh:or ( [ sh:class skos:Concept ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:theme ],
        [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:landingPage ],
        [ sh:or ( [ sh:class rdfs:Resource ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:isReferencedBy ],
        [ sh:datatype rdf:langString ;
            sh:path skos:definition ],
        [ sh:datatype xsd:string ;
            sh:path dcterms:language ],
        [ sh:datatype rdf:langString ;
            sh:path dcterms:title ],
        [ sh:path dcat:version ],
        [ sh:or ( [ sh:class foaf:Document ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:documentation ],
        [ sh:or ( [ sh:class <http://www.w3.org/2006/vcard/ns#Kind> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcat:contactPoint ],
        [ sh:or ( [ sh:class <https://w3id.org/emmo/application/datadoc#ConformanceLevel> ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path <https://w3id.org/emmo/application/datadoc#conformance> ],
        [ sh:or ( [ sh:class foaf:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:publisher ],
        [ sh:datatype xsd:dateTime ;
            sh:path <https://w3id.org/emmo/application/datadoc#curationDate> ],
        [ sh:or ( [ sh:class dcterms:Standard ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path dcterms:conformsTo ] ;
    sh:targetClass dcat:Resource .

ssbd:SemiSupervicedLearningModelShape a sh:NodeShape ;
    sh:targetClass ssbd:SemiSupervicedLearningModel .

ssbd:SoftwareShape a sh:NodeShape ;
    sh:node ssbd:DataShape ;
    sh:property [ sh:or ( [ sh:class ssbd:Model ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:implementsModel ],
        [ sh:datatype xsd:boolean ;
            sh:path ssbd:hasAPI ],
        [ sh:or ( [ sh:class ssbd:Software ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:isSubmoduleOf ],
        [ sh:datatype xsd:boolean ;
            sh:path ssbd:hasGUI ],
        [ sh:or ( [ sh:class ssbd:Software ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:priorRelease ] ;
    sh:targetClass ssbd:Software .

ssbd:AgentShape a sh:NodeShape ;
    sh:node ssbd:AgentShape ;
    sh:property [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:attributed ],
        [ sh:path dcterms:identifier ],
        [ sh:datatype xsd:string ;
            sh:path foaf:name ] ;
    sh:targetClass prov:Agent,
        foaf:Agent .

ssbd:ComputerVisionShape a sh:NodeShape ;
    sh:node ssbd:PerceptionModelShape ;
    sh:targetClass ssbd:ComputerVision .

ssbd:DimensionalityReductionShape a sh:NodeShape ;
    sh:targetClass ssbd:DimensionalityReduction .

ssbd:NaturalLanguageUnderstandingShape a sh:NodeShape ;
    sh:targetClass ssbd:NaturalLanguageUnderstanding .

ssbd:PredictionLearningModelShape a sh:NodeShape ;
    sh:node ssbd:SupervisedLearningModelShape ;
    sh:targetClass ssbd:PredictionLearningModel .

ssbd:SignShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:property [ sh:or ( [ sh:class ssbd:Interpreter ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:isInterpretedBy ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:standsFor ] ;
    sh:targetClass ssbd:Sign .

ssbd:SupervisedLearningModelShape a sh:NodeShape ;
    sh:targetClass ssbd:SupervisedLearningModel .

ssbd:ClassificationShape a sh:NodeShape ;
    sh:node ssbd:SupervisedLearningModelShape ;
    sh:targetClass ssbd:Classification .

ssbd:SsbdDimensionShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:SsbdDimension .

ssbd:SymbolicDataShape a sh:NodeShape ;
    sh:node ssbd:DataShape ;
    sh:targetClass ssbd:SymbolicData .

ssbd:CognitionAndLearningModelShape a sh:NodeShape ;
    sh:targetClass ssbd:CognitionAndLearningModel .

ssbd:DataShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:property [ sh:path ssbd:hasDataValue ] ;
    sh:targetClass ssbd:Data .

ssbd:DeepLearningModelShape a sh:NodeShape ;
    sh:node ssbd:ArtificialNeuralNetworkShape ;
    sh:targetClass ssbd:DeepLearningModel .

ssbd:EntityShape a sh:NodeShape ;
    sh:property [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:participatesTo ],
        [ sh:or ( [ sh:class ssbd:Matter ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:chemicalClass ],
        [ sh:or ( [ sh:class ssbd:TierLevel ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:tierLevel ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path prov:wasAttributedTo ],
        [ sh:or ( [ sh:class prov:Agent ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasAttributedTo ],
        [ sh:or ( [ sh:class ssbd:Sign ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:isRepresentedBy ],
        [ sh:or ( [ sh:class prov:Entity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasDerivedBy ],
        [ sh:or ( [ sh:class prov:Activity ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:wasGeneratedBy ] ;
    sh:targetClass prov:Entity .

