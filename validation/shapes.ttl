        [ sh:or ( [ sh:class ssbd:Model ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:implementsModel ],
        [ sh:or ( [ sh:class ssbd:Software ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:isSubmoduleOf ] ;
