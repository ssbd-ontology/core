    sh:targetClass ssbd:MagneticMaterial .

ssbd:MaterialProcessShape a sh:NodeShape ;
    sh:node ssbd:ProcessShape ;
    sh:targetClass ssbd:MaterialProcess .

ssbd:MatterShape a sh:NodeShape ;
    sh:node ssbd:EntityShape ;
    sh:targetClass ssbd:Matter .

ssbd:MeasurementShape a sh:NodeShape ;
    sh:node ssbd:ProcessShape ;
    sh:targetClass ssbd:Measurement .

ssbd:MediaTypeShape a sh:NodeShape ;
    sh:targetClass dcterms:MediaType .

ssbd:MicroMoleculeShape a sh:NodeShape ;
    sh:targetClass ssbd:MicroMolecule .

ssbd:ModelShape a sh:NodeShape ;
    sh:node ssbd:SignShape ;
    sh:targetClass ssbd:Model .

ssbd:MonteCarloLearningModelShape a sh:NodeShape ;
    sh:node ssbd:ReinforcedLearningModelShape ;
    sh:targetClass ssbd:MonteCarloLearningModel .

ssbd:NaiveBayesShape a sh:NodeShape ;
    sh:node ssbd:ClassificationShape ;
    sh:targetClass ssbd:NaiveBayes .

ssbd:NanoCompositeShape a sh:NodeShape ;
    sh:node ssbd:NanoStructuredMaterialShape ;
    sh:targetClass ssbd:NanoComposite .

ssbd:NanoParticleShape a sh:NodeShape ;
    sh:node ssbd:NanoObjectShape ;
    sh:targetClass ssbd:NanoParticle .

ssbd:NanoPlateShape a sh:NodeShape ;
