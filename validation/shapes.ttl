ssbd:SsbdDatasetShape a sh:NodeShape ;
    sh:node ssbd:DcatDatasetShape,
        ssbd:SsbdDataShape ;
    sh:property [ sh:or ( [ sh:class ssbd:Datum ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasPart ],
        [ sh:or ( [ sh:class ssbd:Datum ] [ sh:nodeKind sh:IRI ] ) ;
            sh:path ssbd:hasDatum ] ;
    sh:targetClass ssbd:Dataset .

ssbd:SsbdDateDataShape a sh:NodeShape ;
