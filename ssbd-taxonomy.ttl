@prefix : <https://w3id.org/ssbd/ssbd-taxonomy#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ssbd: <https://w3id.org/ssbd/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/ssbd/ssbd-taxonomy> .

<https://w3id.org/ssbd/core/ssbd-taxonomy> rdf:type owl:Ontology ;
                                       owl:versionIRI <https://w3id.org/ssbd/core/0.0.1/ssbd-taxonomy> ;
                                       dcterms:abstract "Taxonomy useful for categorizing activities and outputs of activities within the SSbD framework."@en ;
                                       dcterms:title "SSbD Taxonomy"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
dcterms:abstract rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/ssbd/assesses
ssbd:assesses rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/ssbd/AcidificationImpactAssessment
ssbd:AcidificationImpactAssessment rdf:type owl:Class ;
                                   rdfs:subClassOf ssbd:LifeCycleImpactAssessmentCategory ;
                                   skos:altLabel "Acidification" ;
                                   skos:definition "Assesses the potential for emissions like SO? and NOx to form acid rain, thereby harming soil, water, and ecosystems"@en ;
                                   skos:prefLabel "AcidificationImpactCategory"@en .


###  https://w3id.org/ssbd/AcuteToxicityAssessment
ssbd:AcuteToxicityAssessment rdf:type owl:Class ;
                             rdfs:subClassOf ssbd:HazardIdentificationHumanHealth ;
                             skos:altLabel "Acute Toxicity ?Assessment" ;
                             skos:definition "Assessment of toxicity from acute exposure (acute  refers to studies where dosing is either single or limited to one day although the total study duration may extend to two weeks to permit appearance of toxicity in susceptible organ systems)"@en ;
                             skos:prefLabel "AcuteToxicity?Assessment"@en .


###  https://w3id.org/ssbd/AmbientAirQualityAssessment
ssbd:AmbientAirQualityAssessment rdf:type owl:Class ;
                                 rdfs:subClassOf ssbd:ExposureAssessmentEnvironment ;
                                 skos:altLabel "Ambient Air Quality Assessment" ;
                                 skos:definition "Assessing the concentration of air pollutants"@en ;
                                 skos:prefLabel "AmbientAirQualityAssessment"@en .


###  https://w3id.org/ssbd/AquaticToxicityFreshwater
ssbd:AquaticToxicityFreshwater rdf:type owl:Class ;
                               rdfs:subClassOf ssbd:EnvironmentalRiskAssessment ;
                               skos:altLabel "Aquatic Toxicity Freshwater" ;
                               skos:definition "Risks to freshwater organisms"@en ;
                               skos:prefLabel "AquaticToxicityFreshwater"@en .


###  https://w3id.org/ssbd/AquaticToxicityMarine
ssbd:AquaticToxicityMarine rdf:type owl:Class ;
                           rdfs:subClassOf ssbd:EnvironmentalRiskAssessment ;
                           skos:altLabel "Aquatic Toxicity Marine" ;
                           skos:definition "Risks to marine organisms"@en ;
                           skos:prefLabel "AquaticToxicityMarine"@en .


###  https://w3id.org/ssbd/BehaviouralImmunotoxicityAssessment
ssbd:BehaviouralImmunotoxicityAssessment rdf:type owl:Class ;
                                         rdfs:subClassOf ssbd:HazardIdentificationHumanHealth ;
                                         skos:altLabel "Behavioural Immunotoxicity Assessment" ;
                                         skos:prefLabel "BehaviouralImmunotoxicityAssessment"@en .


###  https://w3id.org/ssbd/BioaccumulationAssessment
ssbd:BioaccumulationAssessment rdf:type owl:Class ;
                               rdfs:subClassOf ssbd:ExposureAssessmentEnvironment ;
                               skos:altLabel "Bioaccumulation Assessment" ;
                               skos:definition "Assessing the bioaccumulation potential"@en ;
                               skos:prefLabel "BioaccumulationAssessment"@en ;
                               skos:scopeNote "Bioaccumulation refers to the accumulation of persistent hydrophobic chemicals in aquatic organisms through mechanisms such as direct uptake from water via gills or skin (bioconcentration), ingestion of suspended particles, or consumption of contaminated food (biomagnification).  It is the progressive increase in the amount of a substance in an organism or part of an organism that occurs because the rate of intake from all contributing sources and by all possible routes exceeds the organism’s ability to eliminate the substance from its body" .


###  https://w3id.org/ssbd/BiodegradabilityAssessment
ssbd:BiodegradabilityAssessment rdf:type owl:Class ;
                                rdfs:subClassOf ssbd:ExposureAssessmentEnvironment ;
                                skos:altLabel "Biodegradability Assessment" ;
                                skos:definition "Tests to assess biodegradability."@en ;
                                skos:prefLabel "BiodegradabilityAssessment"@en ;
                                skos:scopeNote "Biodegradation is the breakdown of matter into smaller parts and eventual conversion into substances that are reused in biological cycles or accumulate in the environment" .


###  https://w3id.org/ssbd/BiodiversityAssessment
ssbd:BiodiversityAssessment rdf:type owl:Class ;
                            rdfs:subClassOf ssbd:EnvironmentalSustainabilityAssessment ;
                            skos:altLabel "Biodiversity Assessment" ;
                            skos:prefLabel "BiodiversityAssessment"@en .


###  https://w3id.org/ssbd/BulkModulusAssessment
ssbd:BulkModulusAssessment rdf:type owl:Class ;
                           rdfs:subClassOf ssbd:MechanicalPropertiesAssessment ;
                           skos:altLabel "Bulk Modulus Assessment" ;
                           skos:definition "Assessment of bulk modulus of materials."@en ;
                           skos:prefLabel "BulkModulusAssessment"@en .


###  https://w3id.org/ssbd/CarcinogenicityAssessment
ssbd:CarcinogenicityAssessment rdf:type owl:Class ;
                               rdfs:subClassOf ssbd:HazardIdentificationHumanHealth ;
                               skos:altLabel "Carcinogenicity Assessment" ;
                               skos:definition """Test(s) carried out over a sufficient time to detect any possible carcinogenic effect of a
test substance"""@en ;
                               skos:prefLabel "CarcinogenicityAssessment"@en .


###  https://w3id.org/ssbd/DensityAssessment
ssbd:DensityAssessment rdf:type owl:Class ;
                       rdfs:subClassOf ssbd:PhysicalPropertiesAssessment ;
                       skos:altLabel "Density Assessment" ;
                       skos:definition "Assessment of density of chemicals and materials."@en ;
                       skos:prefLabel "DensityAssessment"@en .


###  https://w3id.org/ssbd/DevelopmentalNeurotoxicityAssessment
ssbd:DevelopmentalNeurotoxicityAssessment rdf:type owl:Class ;
                                          rdfs:subClassOf ssbd:HazardIdentificationHumanHealth ;
                                          skos:altLabel "Developmental Neurotoxicity Assessment" ;
                                          skos:definition "Any examination that allows detection of substance-induced changes in the structural or functional integrity of the nervous system of a developing organism."@en ;
                                          skos:prefLabel "DevelopmentalNeurotoxicityAssessment"@en .


###  https://w3id.org/ssbd/EconomicDimension
ssbd:EconomicDimension rdf:type owl:Class ;
                       rdfs:subClassOf ssbd:SSbDDimension ;
                       skos:altLabel "Economic Dimension" ;
                       skos:definition "The dimension of economic impact in the context of SSbD assessments."@en ;
                       skos:prefLabel "EconomicDimension"@en .


###  https://w3id.org/ssbd/EconomicSustainabilityAssessment
ssbd:EconomicSustainabilityAssessment rdf:type owl:Class ;
                                      rdfs:subClassOf ssbd:SSbDSpecifiedAssessment ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty ssbd:assesses ;
                                                        owl:someValuesFrom ssbd:EconomicSustainabilityDimension
                                                      ] ;
                                      skos:altLabel "Economic Sustainability Assessment" ;
                                      skos:definition "Assessment of economic sustainability aspects of chemicals and materials during production, use, and disposal"@en ;
                                      skos:prefLabel "EconomicSustainabilityAssessment"@en ;
                                      skos:scopeNote "The superclass of all SSbD Assessments within the dimension economic sustainability" .


###  https://w3id.org/ssbd/EconomicSustainabilityDimension
ssbd:EconomicSustainabilityDimension rdf:type owl:Class ;
                                     rdfs:subClassOf ssbd:SSbDDimension ;
                                     skos:altLabel "Economic Sustainability Dimension" ;
                                     skos:prefLabel "EconomicSustainabilityDimension"@en .


###  https://w3id.org/ssbd/EndocrineToxicityAssessment
ssbd:EndocrineToxicityAssessment rdf:type owl:Class ;
                                 rdfs:subClassOf ssbd:HazardIdentificationHumanHealth ;
                                 skos:altLabel "Endocrine Toxicity Assessment" ;
                                 skos:prefLabel "EndocrineToxicityAssessment"@en .


###  https://w3id.org/ssbd/EnergyConsumptionAssessment
ssbd:EnergyConsumptionAssessment rdf:type owl:Class ;
                                 rdfs:subClassOf ssbd:EnvironmentalSustainabilityAssessment ;
                                 skos:altLabel "Energy Consumption Assessment" ;
                                 skos:definition "Assessing the energy consumption during production of chemicals and materials"@en ;
                                 skos:prefLabel "EnergyConsumptionAssessment"@en .


###  https://w3id.org/ssbd/EnvironmentalDimension
ssbd:EnvironmentalDimension rdf:type owl:Class ;
                            rdfs:subClassOf ssbd:SSbDDimension ;
                            skos:definition "The dimension of environmental impact in the context of SSbD assessments."@en ;
                            skos:prefLabel "EnvironmentalDimension"@en .


###  https://w3id.org/ssbd/EnvironmentalExternalitiesAssessment
ssbd:EnvironmentalExternalitiesAssessment rdf:type owl:Class ;
                                          rdfs:subClassOf ssbd:ExternalitiesAssessment ;
                                          skos:altLabel "Environmental Externalities Assessment" ;
                                          skos:definition "Assessment of enviornmental externalities."@en ;
                                          skos:prefLabel "EnvironmentalExternalitiesAssessment"@en .


###  https://w3id.org/ssbd/EnvironmentalRiskAssessment
ssbd:EnvironmentalRiskAssessment rdf:type owl:Class ;
                                 rdfs:subClassOf ssbd:SafetyAssessment ;
                                 skos:altLabel "Environmental Risk Assessment" ;
                                 skos:definition "ERA focuses on the risks chemicals pose to ecological organisms like fish, birds, and forests."@en ;
                                 skos:prefLabel "EnvironmentalRiskAssessment"@en .


###  https://w3id.org/ssbd/EnvironmentalSustainabilityAssessment
ssbd:EnvironmentalSustainabilityAssessment rdf:type owl:Class ;
                                           rdfs:subClassOf ssbd:SSbDSpecifiedAssessment ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty ssbd:assesses ;
                                                             owl:someValuesFrom ssbd:EnvironmentalSustainabilityDimension
                                                           ] ;
                                           skos:altLabel "Environmental Sustainability Assessment" ;
                                           skos:definition "Assessment of environmental sustainability aspects of chemicals and materials during production, use, and disposal"@en ;
                                           skos:prefLabel "EnvironmentalSustainabilityAssessment"@en ;
                                           skos:scopeNote "The superclass of all SSbD Assessments within the dimension environmental sustainability" .


###  https://w3id.org/ssbd/EnvironmentalSustainabilityDimension
ssbd:EnvironmentalSustainabilityDimension rdf:type owl:Class ;
                                          rdfs:subClassOf ssbd:SSbDDimension ;
                                          skos:altLabel "Environmental Sustainability Dimension" ;
                                          skos:prefLabel "EnvironmentalSustainabilityDimension"@en .


###  https://w3id.org/ssbd/ExposureAssessmentEnvironment
ssbd:ExposureAssessmentEnvironment rdf:type owl:Class ;
                                   rdfs:subClassOf ssbd:SafetyAssessment ;
                                   skos:definition "Description of the presence and characteristics of contact between a contaminant and an ecological entity of concern, and a summary of this information in an exposure profile."@en .


###  https://w3id.org/ssbd/ExposureAssessmentHumanHealth
ssbd:ExposureAssessmentHumanHealth rdf:type owl:Class ;
                                   rdfs:subClassOf ssbd:SafetyAssessment ;
                                   skos:altLabel "Exposure Assessment Human Health" ;
                                   skos:definition "Estimates the magnitude, frequency, duration, and route of exposure to the chemical for humans or environment for the relevant exposure pattern (population, route, and duration of exposure) and each relevant health effect (local and systemic effects) under realistic or worst-case scenarios."@en ;
                                   skos:prefLabel "ExposureAssessmentHumanHealth"@en .


###  https://w3id.org/ssbd/ExternalitiesAssessment
ssbd:ExternalitiesAssessment rdf:type owl:Class ;
                             rdfs:subClassOf ssbd:EconomicSustainabilityAssessment ;
                             skos:altLabel "Externalities Assessment" ;
                             skos:definition "Externalities assessment is the process of identifying, quantifying, and valuing the indirect costs or benefits of economic activities imposed on third parties—such as environmental damage, pollution, health impacts, cultural heritage loss, loss of traditional livelihoods—that are not reflected in market prices"@en ;
                             skos:prefLabel "ExternalitiesAssessment"@en ;
                             skos:scopeNote "Activity by one party causes a cost or benefit to another party" .


###  https://w3id.org/ssbd/FairRenumerationAssessment
ssbd:FairRenumerationAssessment rdf:type owl:Class ;
                                rdfs:subClassOf ssbd:WorkerSocialResponsibilityAssessment ;
                                skos:altLabel "Fair Renumeration" ;
                                skos:prefLabel "FairRenumerationAssessment"@en .


###  https://w3id.org/ssbd/FlammabiityAssessment
ssbd:FlammabiityAssessment rdf:type owl:Class ;
                           rdfs:subClassOf ssbd:IntrinsicChemicalHazardAssessment ;
                           skos:altLabel "Flammabiity Assessment" ;
                           skos:definition "Assessment of Flammability of chemicals and substances"@en ;
                           skos:prefLabel "FlammabiityAssessment"@en .


###  https://w3id.org/ssbd/FossilFuelEnergyConsumptionAssessment
ssbd:FossilFuelEnergyConsumptionAssessment rdf:type owl:Class ;
                                           rdfs:subClassOf ssbd:EnergyConsumptionAssessment ;
                                           skos:altLabel "Fossil Fuel Energy Consumption Assessment" ;
                                           skos:definition "Assessing the non-renewable energy consumption during production of chemicals and materials"@en ;
                                           skos:prefLabel "FossilFuelEnergyConsumptionAssessment"@en .


###  https://w3id.org/ssbd/FreshwaterAquaticEcotoxicityImpactAssessment
ssbd:FreshwaterAquaticEcotoxicityImpactAssessment rdf:type owl:Class ;
                                                  rdfs:subClassOf ssbd:LifeCycleImpactAssessmentCategory ;
                                                  skos:altLabel "Freshwater Aquatic Ecotoxicity" ;
                                                  skos:prefLabel "FreshwaterAquaticEcotoxicityImpactCategory"@en .


###  https://w3id.org/ssbd/FreshwaterEutrophicationImpactAssessment
ssbd:FreshwaterEutrophicationImpactAssessment rdf:type owl:Class ;
                                              rdfs:subClassOf ssbd:LifeCycleImpactAssessmentCategory ;
                                              skos:altLabel "Freshwater Eutrophication" ;
                                              skos:prefLabel "FreshwaterEutrophicationImpactCategory"@en .


###  https://w3id.org/ssbd/FunctionalityAssessment
ssbd:FunctionalityAssessment rdf:type owl:Class ;
                             rdfs:subClassOf ssbd:SSbDSpecifiedAssessment ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty ssbd:assesses ;
                                               owl:someValuesFrom ssbd:FunctionalityDimension
                                             ] ;
                             skos:altLabel "Functionality Assessment" ;
                             skos:definition "Assessment of functionality of chemicals and materials"@en ,
                                             "The superclass of all SSbD Assessments within the dimenstion functionality."@en ;
                             skos:prefLabel "FunctionalityAssessment"@en ;
                             skos:scopeNote "The superclass of all SSbD Assessments within the dimenstion functionality" .


###  https://w3id.org/ssbd/FunctionalityDimension
ssbd:FunctionalityDimension rdf:type owl:Class ;
                            rdfs:subClassOf ssbd:SSbDDimension ;
                            skos:altLabel "Functionality Dimension" ;
                            skos:definition "The dimension of functionality in the context of SSbD assessments."@en ,
                                            """The term functionality is defined as the quality of being useful, practical, and fit-for- purpose for which something was made. It is neither a property nor an application itself. It is rather the relationship between the use-oriented (functional) properties and the practical use of a chemical or material in such a way that the use of the chemical or material has a positive influence on a task or a potential application.
Suggested definition from :https://www.oecd.org/en/publications/safe-and-sustainable-by-design-tools-integrative-systems-and-platforms-for-nanomaterials-and-nano-enabled-products_e411a4b7-en.html"""@en ;
                            skos:prefLabel "FunctionalityDimension"@en .


###  https://w3id.org/ssbd/GlassTransitionTemperatureAssessment
ssbd:GlassTransitionTemperatureAssessment rdf:type owl:Class ;
                                          rdfs:subClassOf ssbd:ThermalPropertiesAssessment ;
                                          skos:altLabel "Glass Transition Temperature Assessmen" ,
                                                        "Glass Transition Temperature Assessment" ;
                                          skos:definition "Assessment of glass transition temperature of materials."@en ;
                                          skos:prefLabel "GlassTransitionTemperatureAssessment"@en .


###  https://w3id.org/ssbd/GlobalWarmingAssessment
ssbd:GlobalWarmingAssessment rdf:type owl:Class ;
                             rdfs:subClassOf ssbd:LifeCycleImpactAssessmentCategory ;
                             skos:altLabel "Global warming (GWP 100)" ;
                             skos:prefLabel "GlobalWarmingPotenial100"@en .


###  https://w3id.org/ssbd/HHRAAirPollution
ssbd:HHRAAirPollution rdf:type owl:Class ;
                      rdfs:subClassOf ssbd:HumanHealthRiskAssessment ;
                      skos:altLabel "HHRA Air Pollution" ;
                      skos:definition "Assessment of human health Risks from Air pollutants"@en ;
                      skos:prefLabel "HHRAAir pollution"@en .


###  https://w3id.org/ssbd/HHRAChemicalSubstances
ssbd:HHRAChemicalSubstances rdf:type owl:Class ;
                            rdfs:subClassOf ssbd:HumanHealthRiskAssessment ;
                            skos:altLabel "HHRA ChemicalSubstances" ;
                            skos:definition "Assessment of Human Health Risks from pesticides, cosmetics, chemicals in flame retardants, etc. This can include dermal exposures, in addition to inhalation and ingestion exposure routes."@en ;
                            skos:prefLabel "HHRAChemicalSubstances"@en .


###  https://w3id.org/ssbd/HHRAIndoorAirPollution
ssbd:HHRAIndoorAirPollution rdf:type owl:Class ;
                            rdfs:subClassOf ssbd:HumanHealthRiskAssessment ;
                            skos:altLabel "HHRA Indoor air pollution" ;
                            skos:definition "Assessment of human health Risks from indoor air pollutants"@en ;
                            skos:prefLabel "HHRAIndoor air pollution"@en .


###  https://w3id.org/ssbd/HHRASoilPollution
ssbd:HHRASoilPollution rdf:type owl:Class ;
                       rdfs:subClassOf ssbd:HumanHealthRiskAssessment ;
                       skos:altLabel "HHRA  Soil pollution" ;
                       skos:definition "Assessment of human health Risks from pollutants in soil"@en ;
                       skos:prefLabel "HHRA Soil pollution"@en .


###  https://w3id.org/ssbd/HHRAWaterPollution
ssbd:HHRAWaterPollution rdf:type owl:Class ;
                        rdfs:subClassOf ssbd:HumanHealthRiskAssessment ;
                        skos:altLabel "HHRA Water Pollution" ;
                        skos:definition "Assessment of human health Risks from pollutants in drinking water"@en ;
                        skos:prefLabel "HHRAWaterPollution"@en .


###  https://w3id.org/ssbd/HazardAssessmentEnvironment
ssbd:HazardAssessmentEnvironment rdf:type owl:Class ;
                                 rdfs:subClassOf ssbd:SafetyAssessment ;
                                 skos:altLabel "Hazard Assessment Environment" ;
                                 skos:definition "Determination of factors controlling the likely effects of a hazard, such as the dose–effect and dose–response relationships, variations in target susceptibility, bioaccumulation potential, persistence, and mechanism of toxicity."@en ;
                                 skos:prefLabel "HazardAssessmentEnvironment"@en .


###  https://w3id.org/ssbd/HazardAssessmentHumanHealth
ssbd:HazardAssessmentHumanHealth rdf:type owl:Class ;
                                 rdfs:subClassOf ssbd:SafetyAssessment ;
                                 skos:altLabel "Hazard Assessment Human Health" ;
                                 skos:definition "Determination of factors controlling the likely effects of a hazard, such as the dose–effect and dose–response relationships, variations in target susceptibility, bioaccumulation potential, persistence, and mechanism of toxicity."@en ;
                                 skos:prefLabel "HazardAssessmentHumanHealth"@en .


###  https://w3id.org/ssbd/HazardCharacterisationEnvironment
ssbd:HazardCharacterisationEnvironment rdf:type owl:Class ;
                                       rdfs:subClassOf ssbd:HazardAssessmentEnvironment ;
                                       skos:altLabel "Hazard Characterisation Environment" ;
                                       skos:definition "Component of risk assessment concerned with quantifying the manner in which the frequency and intensity of effects increase with increasing exposure of environmental organisms  to a contaminant or other source of stress."@en ;
                                       skos:prefLabel "HazardCharacterisationEnvironment"@en ;
                                       skos:scopeNote "Can also be labelled as dose-response assessment;" .


###  https://w3id.org/ssbd/HazardCharacterisationHumanHealth
ssbd:HazardCharacterisationHumanHealth rdf:type owl:Class ;
                                       rdfs:subClassOf ssbd:HazardAssessmentHumanHealth ;
                                       skos:definition "Establishes the relationship between the dose or concentration of a chemical and the severity or probability of adverse effects. This includes identifying critical effects and determining reference tolerable exposure limit."@en ;
                                       skos:scopeNote "Qualitative and,wherever possible, quantitative description of the nature of the hazard associatedwith the agent of concern." .


###  https://w3id.org/ssbd/HazardIdentificationEnvironment
ssbd:HazardIdentificationEnvironment rdf:type owl:Class ;
                                     rdfs:subClassOf ssbd:SafetyAssessment ;
                                     skos:altLabel "Hazard Identification Environment" ;
                                     skos:definition "Hazard identification is the process of determining whether exposure to a substance can cause a specific adverse effect on organisms in the environment"@en ;
                                     skos:prefLabel "HazardIdentificationEnvironment"@en .


###  https://w3id.org/ssbd/HazardIdentificationHumanHealth
ssbd:HazardIdentificationHumanHealth rdf:type owl:Class ;
                                     rdfs:subClassOf ssbd:HazardAssessmentHumanHealth ;
                                     skos:altLabel "Hazard Identification Human Health" ;
                                     skos:definition "Hazard identification is the process of determining whether exposure to a substance can cause a specific adverse effect on human health. Adverse effect is defined as change in morphology, physiology, growth, reproduction, development, or lifespan of an organism which results in impairment of functional capacity or impairment of capacity to compensate for additional stress or increased susceptibility to the harmful effects of other environmental influences."@en ;
                                     skos:prefLabel "HazardIdentificationHumanHealth"@en ;
                                     skos:scopeNote "Determination of whether the intrinsic properties of a chemical may cause harm (e.g. carcinogenicity, reproductive toxicity, ecotoxicity Ref: Bracalente, Giulio, et al. Safe and Sustainable by Design Chemicals and Materials. Publications Office of the European Union, 2025. EUR. Publications Office of the European Union, https://data.europa.eu/doi/10.2760/5103785." .


###  https://w3id.org/ssbd/HepatotoxicityAssessment
ssbd:HepatotoxicityAssessment rdf:type owl:Class ;
                              rdfs:subClassOf ssbd:HazardIdentificationHumanHealth ;
                              skos:altLabel "Hepatotoxicity Assessment" ;
                              skos:prefLabel "HepatotoxicityAssessment"@en .


###  https://w3id.org/ssbd/HumanHealthRiskAssessment
ssbd:HumanHealthRiskAssessment rdf:type owl:Class ;
                               rdfs:subClassOf ssbd:SafetyAssessment ;
                               skos:altLabel "Human Health Risk Assessment" ;
                               skos:definition "Integrates hazard and exposure information to estimate the likelihood and severity of harm to human health under specific use conditions."@en ;
                               skos:prefLabel "HumanHealthRiskAssessment"@en .


###  https://w3id.org/ssbd/HumanToxicityCancerImpactAssessment
ssbd:HumanToxicityCancerImpactAssessment rdf:type owl:Class ;
                                         rdfs:subClassOf ssbd:LifeCycleImpactAssessmentCategory ;
                                         skos:altLabel "Human carcinogenic toxicity" ;
                                         skos:definition "Evaluating cancer risks caused by inhaling, ingesting, or absorbing chemical substances from environmental emissions (air, water, soil)"@en ;
                                         skos:prefLabel "HumanToxicityCancerImpactCategory"@en .


###  https://w3id.org/ssbd/HumanToxicityNonCancerImpactAssessment
ssbd:HumanToxicityNonCancerImpactAssessment rdf:type owl:Class ;
                                            rdfs:subClassOf ssbd:LifeCycleImpactAssessmentCategory ;
                                            skos:altLabel "Human noncarcinogenic toxicity" ;
                                            skos:definition "Evaluating the adverse health effects on human, excluding cancer, caused by inhaling, ingesting, or absorbing chemical substances from environmental emissions (air, water, soil)"@en ;
                                            skos:prefLabel "HumanToxicityNonCancerImpactCategory"@en .


###  https://w3id.org/ssbd/ImmunotoxicityAssessment
ssbd:ImmunotoxicityAssessment rdf:type owl:Class ;
                              rdfs:subClassOf ssbd:HazardIdentificationHumanHealth ;
                              skos:altLabel "Immunotoxicity Assessment" ;
                              skos:prefLabel "Immunotoxicity?Assessment"@en .


###  https://w3id.org/ssbd/IntrinsicChemicalHazardAssessment
ssbd:IntrinsicChemicalHazardAssessment rdf:type owl:Class ;
                                       rdfs:subClassOf ssbd:SafetyAssessment ;
                                       skos:altLabel "Intrinsic Chemical Hazard Assessment" ;
                                       skos:definition "Intrinsic Chemical Hazard Assessment is the systematic process of identifying and characterizing the inherent harmful properties of a chemical substance, independent of exposure scenarios. This assessment focuses on the substance’s capacity to cause adverse effects on human health or the environment under any circumstances."@en ;
                                       skos:prefLabel "IntrinsicChemicalHazardAssessment"@en .


###  https://w3id.org/ssbd/IrritationAndCorrosion
ssbd:IrritationAndCorrosion rdf:type owl:Class ;
                            rdfs:subClassOf ssbd:HazardIdentificationHumanHealth ;
                            skos:altLabel "Irritation and Corrosion" ;
                            skos:definition "Irritation and corrosion refers local effects on the skin, in the eyes or in respiratory system."@en ;
                            skos:prefLabel "Irritation And Corrosion"@en .


###  https://w3id.org/ssbd/LifeCycleImpactAssessmentCategory
ssbd:LifeCycleImpactAssessmentCategory rdf:type owl:Class ;
                                       rdfs:subClassOf ssbd:EnvironmentalSustainabilityAssessment ;
                                       skos:altLabel "Life Cycle Assessment Impact Category" ;
                                       skos:definition "A LCA impact category groups different emissions into one effect on the environment"@en ;
                                       skos:prefLabel "LifeCycleAssessmentImpactCategory"@en .


